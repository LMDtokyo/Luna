extern "linux_syscall" fn sys_write(@fd: int, @buf: int, @n: int) -> int

fn print_line(@s: int, @n: int) -> int
    sys_write(1, @s, @n)
    return 0

fn main() -> int
    let @i = 1
    while @i <= 15
        if @i == 3
            print_line("Fizz\n", 5)
        if @i == 5
            print_line("Buzz\n", 5)
        if @i == 15
            print_line("FizzBuzz!\n", 10)
        @i = @i + 1
    return 0
