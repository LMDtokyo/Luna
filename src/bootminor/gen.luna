# =====================================================================
# bootminor M2b: single-pass parser + codegen.
#
# Consumes the token stream produced by lex.luna and emits x86-64
# machine code directly into a StrBuf. No explicit AST.
#
# Subset:
#   fn main() -> int
#       @name = <expr>
#       shine("literal")
#       shine_int(<expr>)
#       if <cond> / elif / else  (indented blocks)
#       while <cond>
#       return <expr>
#
# Expression grammar (precedence-climbing, lowest → highest):
#   expr   := cmp
#   cmp    := add ( ("==" | "!=" | "<" | "<=" | ">" | ">=") add )*
#   add    := mul ( ("+" | "-") mul )*
#   mul    := unary ( ("*" | "/" | "%") unary )*
#   unary  := ("-")? primary
#   primary:= INT | ATIDENT | "(" expr ")"
#
# Calling convention for binops: parse_X leaves the left operand in
# rax, saves it on the stack, parses the right into rax, then moves
# right into rcx, pops left into rax, and emits the operation so that
# rax holds (left OP right). This matches the C/x86 convention.
# =====================================================================


# --- Struct ----------------------------------------------------------

struct Gen
    code:        int
    data:        int
    kind:        int
    start:       int
    tlen:        int
    iv:          int
    pos:         int
    src:         int
    names:       int     # locals of current fn being parsed (names)
    offs:        int     # locals of current fn (stack offsets)
    frame:       int     # current frame size
    pi_off:      int     # print_int helper code offset
    fn_names:    int     # global fn table: name ptrs
    fn_offsets:  int     # global fn table: code offsets
    fn_patches:  int     # forward-call patches: [call_site_off, name_ptr]*
    str_patches: int     # LEA str patches: [code_off, data_off]*
    is_main:     int     # 1 while parsing `main`, 0 otherwise
    main_off:    int     # code offset where main starts
    heap_patches: int    # LEA heap_top patches: [code_off]*
    loop_cont:   int     # Vec<int>: stack of continue targets (loop starts)
    loop_breaks: int     # Vec<int>: stack of break-patches-vec pointers
    struct_names:   int  # Vec<str>: declared struct names
    struct_fields:  int  # Vec<Vec>: parallel — each struct's field name list
    local_types:    int  # Vec<str>: type name for each local (or "" if untyped)
    const_names:    int  # Vec<str>: module-level const names
    const_values:   int  # Vec<int>: parallel — their integer values
    local_sealed:   int  # Vec<int>: 1 if local was bound via `seal`, else 0
    hot_slots_off:  int  # data offset of hotswap fn-slots array (8 bytes each)
    hot_names_off:  int  # data offset of fn-name-ptr array (8 bytes each)
    hot_pool_off:   int  # data offset of name pool (concatenated NUL names)
    hot_meta_off:   int  # data offset of hotswap metadata (3 u64 values)
    hotmeta_patches: int # Vec of (code_disp32_off, meta_byte_off) pairs
    enum_names:      int # Vec<str>: declared enum type names
    variant_enum:    int # Vec<str>: for each variant, parent enum name
    variant_name:    int # Vec<str>: variant identifier
    variant_tag:     int # Vec<int>: tag (0..N-1 within enum)
    variant_payload: int # Vec<int>: 1 if variant carries a payload, else 0
    lambda_names:    int # Vec<str>: synthetic names for deferred lambdas
    lambda_starts:   int # Vec<int>: token pos where each lambda header begins
    lambda_captures: int # Vec<Vec<str>>: captured var names per lambda (by-value)


fn gen_new(@src: int, @kind: int, @start: int, @tlen: int, @iv: int) -> Gen
    let @g: Gen = new_str(384)
    @g.code        = strbuf_new()
    @g.data        = strbuf_new()
    @g.kind        = @kind
    @g.start       = @start
    @g.tlen        = @tlen
    @g.iv          = @iv
    @g.pos         = 0
    @g.src         = @src
    @g.names       = vec_new()
    @g.offs        = vec_new()
    @g.frame       = 0
    @g.pi_off      = 0
    @g.fn_names    = vec_new()
    @g.fn_offsets  = vec_new()
    @g.fn_patches  = vec_new()
    @g.str_patches = vec_new()
    @g.is_main      = 0
    @g.main_off     = 0
    @g.heap_patches = vec_new()
    @g.loop_cont    = vec_new()
    @g.loop_breaks  = vec_new()
    @g.struct_names  = vec_new()
    @g.struct_fields = vec_new()
    @g.local_types   = vec_new()
    @g.const_names   = vec_new()
    @g.const_values  = vec_new()
    @g.local_sealed  = vec_new()
    @g.hot_slots_off    = 0
    @g.hot_names_off    = 0
    @g.hot_pool_off     = 0
    @g.hot_meta_off     = 8
    @g.hotmeta_patches  = vec_new()
    @g.enum_names       = vec_new()
    @g.variant_enum     = vec_new()
    @g.variant_name     = vec_new()
    @g.variant_tag      = vec_new()
    @g.variant_payload  = vec_new()
    @g.lambda_names     = vec_new()
    @g.lambda_starts    = vec_new()
    @g.lambda_captures  = vec_new()
    # Reserve 40 bytes at the very start of the data section:
    #   [0..8)   heap_top (runtime bump pointer)
    #   [8..16)  hotswap slots vaddr       (patched by main2)
    #   [16..24) hotswap fn count          (patched by main2)
    #   [24..32) hotswap names vaddr       (patched by main2)
    #   [32..40) hotswap name pool vaddr   (patched by main2)
    @i = 0
    while @i < 40
        strbuf_add_byte(@g.data, 0)
        @i = @i + 1
    return @g


# --- Token stream helpers --------------------------------------------

fn _peek_kind(@g: Gen) -> int
    return vec_get(@g.kind, @g.pos)

fn _peek_iv(@g: Gen) -> int
    return vec_get(@g.iv, @g.pos)

fn _peek_start(@g: Gen) -> int
    return vec_get(@g.start, @g.pos)

fn _peek_tlen(@g: Gen) -> int
    return vec_get(@g.tlen, @g.pos)

fn _peek_at(@g: Gen) -> int
    return vec_get(@g.kind, @g.pos)

fn _advance(@g: Gen) -> int
    @g.pos = @g.pos + 1
    return 0

fn _accept(@g: Gen, @k: int) -> int
    if _peek_kind(@g) == @k
        _advance(@g)
        return 1
    return 0

fn _die(@g: Gen, @msg: int) -> int
    print("bootminor: ")
    shine(@msg)
    print("  got token kind = ")
    print_int(_peek_kind(@g))
    shine("")
    return 1

fn _expect(@g: Gen, @k: int, @msg: int) -> int
    if _peek_kind(@g) == @k
        _advance(@g)
        return 0
    _die(@g, @msg)
    return 1

# Skip TK_NEWLINE tokens (multiple blank lines).
fn _skip_newlines(@g: Gen) -> int
    while _peek_kind(@g) == TK_NEWLINE
        _advance(@g)
    return 0


# --- Local variable map ----------------------------------------------

fn _tok_substr(@g: Gen, @i: int) -> int
    @s = vec_get(@g.start, @i)
    @l = vec_get(@g.tlen, @i)
    return str_substr(@g.src, @s, @l)

fn _local_slot(@g: Gen, @name: int) -> int
    @n = vec_len(@g.names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.names, @i), @name) == 1
            return vec_get(@g.offs, @i)
        @i = @i + 1
    @g.frame = @g.frame + 8
    @off = 0 - @g.frame
    vec_push(@g.names, @name)
    vec_push(@g.offs, @off)
    vec_push(@g.local_types, "")
    vec_push(@g.local_sealed, 0)
    return @off

# Compound-assignment classifier + op emitter (rax OP= rcx).
fn _is_compound_assign(@k: int) -> int
    if @k == TK_PLUSEQ
        return 1
    if @k == TK_MINUSEQ
        return 1
    if @k == TK_STAREQ
        return 1
    if @k == TK_SLASHEQ
        return 1
    if @k == TK_PERCENTEQ
        return 1
    if @k == TK_AMPEQ
        return 1
    if @k == TK_PIPEEQ
        return 1
    if @k == TK_CARETEQ
        return 1
    if @k == TK_SHLEQ
        return 1
    if @k == TK_SHREQ
        return 1
    return 0

fn _emit_compound_op(@g: Gen, @k: int) -> int
    if @k == TK_PLUSEQ
        _em_add_rax_rcx(@g)
        return 0
    if @k == TK_MINUSEQ
        _em_sub_rax_rcx(@g)
        return 0
    if @k == TK_STAREQ
        _em_imul_rax_rcx(@g)
        return 0
    if @k == TK_SLASHEQ
        _em_idiv_rcx(@g)
        return 0
    if @k == TK_PERCENTEQ
        _em_idiv_rcx(@g)
        _em_mov_rax_rdx(@g)
        return 0
    if @k == TK_AMPEQ
        _em_and_rax_rcx(@g)
        return 0
    if @k == TK_PIPEEQ
        _em_or_rax_rcx(@g)
        return 0
    if @k == TK_CARETEQ
        _em_xor_rax_rcx(@g)
        return 0
    if @k == TK_SHLEQ
        _em_shl_rax_cl(@g)
        return 0
    if @k == TK_SHREQ
        _em_shr_rax_cl(@g)
        return 0
    return 0

# Is the given local sealed? Returns 0 if not declared or not sealed.
fn _local_is_sealed(@g: Gen, @name: int) -> int
    @n = vec_len(@g.names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.names, @i), @name) == 1
            return vec_get(@g.local_sealed, @i)
        @i = @i + 1
    return 0

# Mark a local as sealed.
fn _seal_local(@g: Gen, @name: int) -> int
    @n = vec_len(@g.names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.names, @i), @name) == 1
            vec_set(@g.local_sealed, @i, 1)
            return 0
        @i = @i + 1
    return 0

# Track whether the current binding keyword was `seal` so parse logic
# knows to mark the local immutable after the store.
fn _is_seal_kw(@k: int) -> int
    if @k == TK_KW_SEAL
        return 1
    return 0

# Set the type name for an existing local. Used by `let @x: T = ...`
# and function parameters with explicit type.
fn _set_local_type(@g: Gen, @name: int, @type: int) -> int
    @n = vec_len(@g.names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.names, @i), @name) == 1
            vec_set(@g.local_types, @i, @type)
            return 0
        @i = @i + 1
    return 0

# Get local's recorded type name, or "" if none.
fn _local_type(@g: Gen, @name: int) -> int
    @n = vec_len(@g.names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.names, @i), @name) == 1
            return vec_get(@g.local_types, @i)
        @i = @i + 1
    return ""

# Reset locals between functions. Called at start of each fn decl.
fn _reset_locals(@g: Gen) -> int
    @g.names        = vec_new()
    @g.offs         = vec_new()
    @g.local_types  = vec_new()
    @g.local_sealed = vec_new()
    @g.frame        = 0
    return 0

# Look up a fn's code offset by name. Returns -1 if not yet defined.
fn _fn_lookup(@g: Gen, @name: int) -> int
    @n = vec_len(@g.fn_names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.fn_names, @i), @name) == 1
            return vec_get(@g.fn_offsets, @i)
        @i = @i + 1
    return 0 - 1

# Register a fn definition in the table.
fn _fn_register(@g: Gen, @name: int, @offset: int) -> int
    vec_push(@g.fn_names, @name)
    vec_push(@g.fn_offsets, @offset)
    return 0

# Register a struct declaration.
fn _struct_register(@g: Gen, @name: int, @fields: Vec) -> int
    vec_push(@g.struct_names, @name)
    vec_push(@g.struct_fields, @fields)
    return 0

# Find a struct by name; returns -1 if not found.
fn _struct_lookup(@g: Gen, @name: int) -> int
    @n = vec_len(@g.struct_names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.struct_names, @i), @name) == 1
            return @i
        @i = @i + 1
    return 0 - 1

# Given a struct index and field name, return field index or -1.
fn _field_index(@g: Gen, @s_idx: int, @fname: int) -> int
    @fields = vec_get(@g.struct_fields, @s_idx)
    @n = vec_len(@fields)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@fields, @i), @fname) == 1
            return @i
        @i = @i + 1
    return 0 - 1


# --- Byte emission ---------------------------------------------------

fn _eb(@g: Gen, @v: int) -> int
    strbuf_add_byte(@g.code, @v & 255)
    return 0

fn _e32(@g: Gen, @v: int) -> int
    _eb(@g, @v & 255)
    _eb(@g, (@v >> 8)  & 255)
    _eb(@g, (@v >> 16) & 255)
    _eb(@g, (@v >> 24) & 255)
    return 0

fn _sb_len(@b: StrBuf) -> int
    return @b.len

fn _sb_buf(@b: StrBuf) -> int
    return @b.buf

fn _code_len(@g: Gen) -> int
    return _sb_len(@g.code)

fn _patch32(@g: Gen, @off: int, @v: int) -> int
    @cb = _sb_buf(@g.code)
    str_set_byte(@cb, @off,     @v        & 255)
    str_set_byte(@cb, @off + 1, (@v >> 8)  & 255)
    str_set_byte(@cb, @off + 2, (@v >> 16) & 255)
    str_set_byte(@cb, @off + 3, (@v >> 24) & 255)
    return 0


# --- Instruction emitters --------------------------------------------

# mov eax, imm32 (zero-extended to rax) ; b8 <imm32>
fn _em_mov_eax_imm(@g: Gen, @v: int) -> int
    _eb(@g, 184)
    _e32(@g, @v)
    return 0

# mov rax, imm64 ; 48 b8 <imm64>
fn _em_mov_rax_imm64(@g: Gen, @v: int) -> int
    _eb(@g, 72)
    _eb(@g, 184)
    @i = 0
    while @i < 8
        _eb(@g, (@v >> (@i * 8)) & 255)
        @i = @i + 1
    return 0

# mov edi, imm32 ; bf <imm32>
fn _em_mov_edi_imm(@g: Gen, @v: int) -> int
    _eb(@g, 191)
    _e32(@g, @v)
    return 0

# mov edx, imm32 ; ba <imm32>
fn _em_mov_edx_imm(@g: Gen, @v: int) -> int
    _eb(@g, 186)
    _e32(@g, @v)
    return 0

# mov rdi, rax ; 48 89 c7
fn _em_mov_rdi_rax(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 199)
    return 0

# mov rcx, rax ; 48 89 c1
fn _em_mov_rcx_rax(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 193)
    return 0

# mov rax, rdx ; 48 89 d0  (for modulo: remainder is in rdx after idiv)
fn _em_mov_rax_rdx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 208)
    return 0

# push rax / pop rax / pop rcx
fn _em_push_rax(@g: Gen) -> int
    _eb(@g, 80)
    return 0

fn _em_pop_rax(@g: Gen) -> int
    _eb(@g, 88)
    return 0

fn _em_pop_rcx(@g: Gen) -> int
    _eb(@g, 89)
    return 0

# neg rax ; 48 f7 d8
fn _em_neg_rax(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 247)
    _eb(@g, 216)
    return 0

# mov rax, [rbp + disp32] ; 48 8b 85 disp32
fn _em_load_rbp(@g: Gen, @disp: int) -> int
    _eb(@g, 72)
    _eb(@g, 139)
    _eb(@g, 133)
    _e32(@g, @disp)
    return 0

# mov [rbp + disp32], rax ; 48 89 85 disp32
fn _em_store_rbp(@g: Gen, @disp: int) -> int
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 133)
    _e32(@g, @disp)
    return 0

# Binary ops operate with left in rax, right in rcx (by convention of parse_X).
fn _em_add_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 1)
    _eb(@g, 200)
    return 0

fn _em_sub_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 41)
    _eb(@g, 200)
    return 0

fn _em_imul_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 175)
    _eb(@g, 193)
    return 0

# cqo + idiv rcx ; rdx:rax / rcx -> rax = quot, rdx = rem
fn _em_idiv_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 153)       # cqo
    _eb(@g, 72)
    _eb(@g, 247)
    _eb(@g, 249)       # idiv rcx
    return 0

# cmp rax, rcx ; 48 39 c8
fn _em_cmp_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 57)
    _eb(@g, 200)
    return 0

# and rax, rcx ; 48 21 c8
fn _em_and_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 33)
    _eb(@g, 200)
    return 0

# or rax, rcx ; 48 09 c8
fn _em_or_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 9)
    _eb(@g, 200)
    return 0

# xor rax, rcx ; 48 31 c8
fn _em_xor_rax_rcx(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 49)
    _eb(@g, 200)
    return 0

# not rax ; 48 f7 d0
fn _em_not_rax(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 247)
    _eb(@g, 208)
    return 0

# shl rax, cl ; 48 d3 e0
fn _em_shl_rax_cl(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 211)
    _eb(@g, 224)
    return 0

# shr rax, cl ; 48 d3 e8 (logical right shift)
fn _em_shr_rax_cl(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 211)
    _eb(@g, 232)
    return 0

# setX al ; movzx rax, al  (produces 1 if condition true else 0)
fn _em_set_cond(@g: Gen, @opcode2: int) -> int
    _eb(@g, 15)
    _eb(@g, @opcode2)
    _eb(@g, 192)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 182)
    _eb(@g, 192)
    return 0

# test rax, rax ; 48 85 c0
fn _em_test_rax(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 133)
    _eb(@g, 192)
    return 0

# jz rel32 ; placeholder, returns offset of rel32 bytes
fn _em_jz_placeholder(@g: Gen) -> int
    _eb(@g, 15)
    _eb(@g, 132)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

fn _em_jmp_placeholder(@g: Gen) -> int
    _eb(@g, 233)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

fn _em_jmp_to(@g: Gen, @target: int) -> int
    @here = _code_len(@g)
    @rel = @target - (@here + 5)
    _eb(@g, 233)
    _e32(@g, @rel)
    return 0

fn _em_call_to(@g: Gen, @target: int) -> int
    @here = _code_len(@g)
    @rel = @target - (@here + 5)
    _eb(@g, 232)
    _e32(@g, @rel)
    return 0

# Emit `call rel32` with a zero placeholder. Returns the offset of the
# rel32 bytes so the caller can register a patch for the target name.
fn _em_call_placeholder(@g: Gen) -> int
    _eb(@g, 232)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

# Emit `call qword [rip + disp32]` (6 bytes, ff 15) with a zero
# placeholder. Used for user-fn calls in hot-swap mode so every
# call goes through the dispatch table. Returns the offset of the
# disp32 bytes.
fn _em_call_indirect_placeholder(@g: Gen) -> int
    _eb(@g, 255)                              # FF
    _eb(@g, 21)                               # /2 (near call via r/m64, RIP-rel)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

# Emit `mov rax, qword [rip + disp32]` (7 bytes) — same RIP-relative
# addressing as _em_call_indirect_placeholder. Used to materialise a
# fn pointer value from the hot-swap slot so `@f = fn_name; @f(args)`
# calls the currently-installed body. Returns offset of disp32 bytes.
fn _em_fnptr_load_placeholder(@g: Gen) -> int
    _eb(@g, 72)                               # REX.W
    _eb(@g, 139)                              # 8B
    _eb(@g, 5)                                # /0 mod=00 rm=101 (RIP-rel)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

# call rax  ; FF D0 — indirect call through rax.
fn _em_call_rax(@g: Gen) -> int
    _eb(@g, 255)
    _eb(@g, 208)
    return 0

# Emit `mov rax, qword [rip + disp32]` (7 bytes). Used by hot-swap
# metadata intrinsics. Records a patch pairing (code_disp32_off,
# meta_byte_off) so the driver knows which metadata cell to target.
fn _emit_hotmeta_load(@g: Gen, @meta_off: int) -> int
    _eb(@g, 72)                               # REX.W
    _eb(@g, 139)                              # 8B
    _eb(@g, 5)                                # /0 mod=00 rm=101 (RIP-rel)
    @at = _code_len(@g)
    _e32(@g, 0)
    vec_push(@g.hotmeta_patches, @at)
    vec_push(@g.hotmeta_patches, @meta_off)
    return 0

# mov <arg-reg>, rax for first-6 SysV arg registers.
# i=0 → rdi, 1 → rsi, 2 → rdx, 3 → rcx, 4 → r8, 5 → r9
fn _em_mov_argreg_rax(@g: Gen, @i: int) -> int
    if @i == 0
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 199)                 # mov rdi, rax
        return 0
    if @i == 1
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 198)                 # mov rsi, rax
        return 0
    if @i == 2
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 194)                 # mov rdx, rax
        return 0
    if @i == 3
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 193)                 # mov rcx, rax
        return 0
    if @i == 4
        _eb(@g, 73)                  # REX.WB
        _eb(@g, 137)
        _eb(@g, 192)                 # mov r8, rax
        return 0
    if @i == 5
        _eb(@g, 73)
        _eb(@g, 137)
        _eb(@g, 193)                 # mov r9, rax
        return 0
    return 0

# mov <arg-reg>, [rsp + disp32]  — for i=0..5 SysV arg regs.
fn _em_load_argreg_stack(@g: Gen, @i: int, @disp: int) -> int
    # mov rdi, [rsp + d]   ; 48 8b bc 24 <d>
    # mov rsi, [rsp + d]   ; 48 8b b4 24 <d>
    # mov rdx, [rsp + d]   ; 48 8b 94 24 <d>
    # mov rcx, [rsp + d]   ; 48 8b 8c 24 <d>
    # mov r8,  [rsp + d]   ; 4c 8b 84 24 <d>
    # mov r9,  [rsp + d]   ; 4c 8b 8c 24 <d>
    if @i == 0
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 188)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    if @i == 1
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 180)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    if @i == 2
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 148)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    if @i == 3
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 140)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    if @i == 4
        _eb(@g, 76)
        _eb(@g, 139)
        _eb(@g, 132)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    if @i == 5
        _eb(@g, 76)
        _eb(@g, 139)
        _eb(@g, 140)
        _eb(@g, 36)
        _e32(@g, @disp)
        return 0
    return 0

# pop <arg-reg>  (for i=0..5 SysV arg regs)
fn _em_pop_argreg(@g: Gen, @i: int) -> int
    if @i == 0
        _eb(@g, 95)                  # pop rdi
        return 0
    if @i == 1
        _eb(@g, 94)                  # pop rsi
        return 0
    if @i == 2
        _eb(@g, 90)                  # pop rdx
        return 0
    if @i == 3
        _eb(@g, 89)                  # pop rcx
        return 0
    if @i == 4
        _eb(@g, 65)                  # REX.B
        _eb(@g, 88)                  # pop r8
        return 0
    if @i == 5
        _eb(@g, 65)
        _eb(@g, 89)                  # pop r9
        return 0
    return 0

fn _em_syscall(@g: Gen) -> int
    _eb(@g, 15)
    _eb(@g, 5)
    return 0

# push rbp; mov rbp, rsp; sub rsp, imm32 (returns offset of imm32 for patch)
fn _em_prologue(@g: Gen) -> int
    _eb(@g, 85)
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 229)
    _eb(@g, 72)
    _eb(@g, 129)
    _eb(@g, 236)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

fn _em_epilogue(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 236)
    _eb(@g, 93)
    _eb(@g, 195)
    return 0

# Resolve a forward-jump rel32 whose target is the current code position.
fn _patch_here(@g: Gen, @patch_at: int) -> int
    @here = _code_len(@g)
    @rel = @here - (@patch_at + 4)
    _patch32(@g, @patch_at, @rel)
    return 0

# lea rsi, [rip + disp32] — placeholder; returns offset of the disp32
# bytes for later patching once the string's absolute code-file
# position is known.
fn _em_lea_rsi_rip_ph(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 141)
    _eb(@g, 53)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

# lea rax, [rip + disp32] — placeholder, used for string-literal
# values that appear in expressions (not just inside shine).
# Encoding: 48 8d 05 <disp32>.
fn _em_lea_rax_rip_ph(@g: Gen) -> int
    _eb(@g, 72)
    _eb(@g, 141)
    _eb(@g, 5)
    @at = _code_len(@g)
    _e32(@g, 0)
    return @at

# Append a Luna-style length-prefixed string to the data section.
# Layout: 8-byte little-endian length, then N data bytes. Returns the
# data offset of the FIRST DATA BYTE (i.e. past the length prefix), so
# the caller can LEA to that address and str_len(@s) can read the 8
# bytes right before.
fn _data_add_luna_str(@g: Gen, @src: int) -> int
    @n = str_len(@src)
    # Write 8-byte LE length header.
    @i = 0
    while @i < 8
        strbuf_add_byte(@g.data, (@n >> (@i * 8)) & 255)
        @i = @i + 1
    @data_off = _sb_len(@g.data)
    @j = 0
    while @j < @n
        strbuf_add_byte(@g.data, str_byte(@src, @j))
        @j = @j + 1
    # Trailing NUL so Luna strings passed to C-side syscalls (sys_open
    # etc.) read as valid NUL-terminated C strings.
    strbuf_add_byte(@g.data, 0)
    return @data_off


# --- Linux syscall intrinsic helper ----------------------------------
#
# Evaluates @nargs expressions (currently at @g's token cursor, inside
# enclosing `(...)` punctuation), pushes each, then pops into the
# Linux syscall arg registers: rdi, rsi, rdx, r10, r8, r9. Finally
# sets rax to @syscall_num and emits `syscall`.
#
# The result (rax after syscall) is left in rax so the call can be
# used as an expression.

fn _emit_syscall_intrinsic(@g: Gen, @nargs: int, @syscall_num: int) -> int
    _expect(@g, TK_LPAREN, "expected '(' in syscall")
    @k = 0
    if _peek_kind(@g) != TK_RPAREN
        parse_expr(@g)
        _em_push_rax(@g)
        @k = 1
        while _peek_kind(@g) == TK_COMMA
            _advance(@g)
            parse_expr(@g)
            _em_push_rax(@g)
            @k = @k + 1
    _expect(@g, TK_RPAREN, "expected ')' in syscall")
    # Pop in reverse so arg0 ends up in rdi, arg1 in rsi, etc. Note the
    # Linux convention uses r10 (not rcx) for arg 3.
    @i = @k - 1
    while @i >= 0
        if @i == 0
            _eb(@g, 95)                   # pop rdi
        elif @i == 1
            _eb(@g, 94)                   # pop rsi
        elif @i == 2
            _eb(@g, 90)                   # pop rdx
        elif @i == 3
            # pop r10 ; 41 5a
            _eb(@g, 65)
            _eb(@g, 90)
        elif @i == 4
            _eb(@g, 65)                   # pop r8
            _eb(@g, 88)
        elif @i == 5
            _eb(@g, 65)                   # pop r9
            _eb(@g, 89)
        @i = @i - 1
    # mov eax, syscall_num
    _em_mov_eax_imm(@g, @syscall_num)
    _em_syscall(@g)
    return 0


# --- SSE double binary op: rax = rax OP rcx (as f64 bit patterns) ----
#
# opcode_byte is the third byte of the SSE opcode sequence:
#   addsd = f2 0f 58, subsd = f2 0f 5c, mulsd = f2 0f 59, divsd = f2 0f 5e.
# Encodes: movq xmm0, rax; movq xmm1, rcx; <OP> xmm0, xmm1; movq rax, xmm0

fn _emit_f64_binop(@g: Gen, @op3: int) -> int
    # movq xmm0, rax  ; 66 48 0f 6e c0
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 192)
    # movq xmm1, rcx  ; 66 48 0f 6e c9
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 201)
    # <OP>sd xmm0, xmm1 ; f2 0f <op3> c1
    _eb(@g, 242)
    _eb(@g, 15)
    _eb(@g, @op3)
    _eb(@g, 193)
    # movq rax, xmm0  ; 66 48 0f 7e c0
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 126)
    _eb(@g, 192)
    return 0

# SSE double compare: rax holds result bits of `a`, rcx holds `b`.
# Emits ucomisd xmm0, xmm1 then set<setcc_opcode> al + movzx rax, al.
# Meaning of flags after ucomisd xmm0, xmm1:
#   unordered or equal → ZF=1
#   a > b              → ZF=0, CF=0
#   a < b              → ZF=0, CF=1
# setcc_opcode examples: 148 (sete), 151 (seta, i.e. CF=0 & ZF=0).

fn _emit_f64_cmp(@g: Gen, @setcc: int) -> int
    # movq xmm0, rax (a)
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 192)
    # movq xmm1, rcx (b)
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 201)
    # ucomisd xmm0, xmm1  ; 66 0f 2e c1
    _eb(@g, 102)
    _eb(@g, 15)
    _eb(@g, 46)
    _eb(@g, 193)
    _em_set_cond(@g, @setcc)
    return 0

# Swap operands: useful for a>b variant via ucomisd b,a.
fn _emit_f64_cmp_swap(@g: Gen, @setcc: int) -> int
    # movq xmm0, rcx (b)
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 193)
    # movq xmm1, rax (a)
    _eb(@g, 102)
    _eb(@g, 72)
    _eb(@g, 15)
    _eb(@g, 110)
    _eb(@g, 200)
    # ucomisd xmm0, xmm1
    _eb(@g, 102)
    _eb(@g, 15)
    _eb(@g, 46)
    _eb(@g, 193)
    _em_set_cond(@g, @setcc)
    return 0


# --- Inline new_arr(n): allocate array of n 8-byte slots. ------------
#
# Input:  rax = element count (N)
# Output: rax = pointer to first slot; length prefix at ptr-8 = N
# Layout: [8-byte N][N * 8 bytes of slots] — aligned alloc.

fn _inline_new_arr(@g: Gen) -> int
    # mov rcx, rax                ; save N
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 193)
    # imul rax, rax, 8            ; rax = N*8  (use shift to avoid imul form)
    # shl rax, 3
    _eb(@g, 72)
    _eb(@g, 193)
    _eb(@g, 224)
    _eb(@g, 3)
    # add rax, 16
    _eb(@g, 72)
    _eb(@g, 131)
    _eb(@g, 192)
    _eb(@g, 16)
    # and rax, -8
    _eb(@g, 72)
    _eb(@g, 131)
    _eb(@g, 224)
    _eb(@g, 248)
    # mov r11, rax
    _eb(@g, 73)
    _eb(@g, 137)
    _eb(@g, 195)
    # lea rax, [rip + heap_top]
    _eb(@g, 72)
    _eb(@g, 141)
    _eb(@g, 5)
    @lea_at = _code_len(@g)
    _e32(@g, 0)
    vec_push(@g.heap_patches, @lea_at)
    # mov rsi, [rax]
    _eb(@g, 72)
    _eb(@g, 139)
    _eb(@g, 48)
    # add r11, rsi
    _eb(@g, 73)
    _eb(@g, 1)
    _eb(@g, 243)
    # mov [rax], r11
    _eb(@g, 76)
    _eb(@g, 137)
    _eb(@g, 24)
    # mov [rsi], rcx              ; store N as length prefix
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 14)
    # lea rax, [rsi + 8]
    _eb(@g, 72)
    _eb(@g, 141)
    _eb(@g, 70)
    _eb(@g, 8)
    return 0


# --- _print_int runtime (122 bytes, verified via nasm+ld+run) --------

fn _emit_print_int(@g: Gen) -> int
    @b = [0x55, 0x48, 0x89, 0xe5, 0x48, 0x83, 0xec, 0x20, 0x45, 0x31, 0xc0, 0x48, 0x85, 0xff, 0x79, 0x06, 0x41, 0xb0, 0x01, 0x48, 0xf7, 0xdf, 0xc6, 0x45, 0xff, 0x0a, 0x48, 0x8d, 0x75, 0xff, 0xba, 0x01, 0x00, 0x00, 0x00, 0x48, 0x85, 0xff, 0x75, 0x0d, 0x48, 0x83, 0xee, 0x01, 0xc6, 0x06, 0x30, 0x48, 0x83, 0xc2, 0x01, 0xeb, 0x24, 0x48, 0x89, 0xf8, 0x31, 0xd2, 0xb9, 0x0a, 0x00, 0x00, 0x00, 0x48, 0xf7, 0xf1, 0x80, 0xc2, 0x30, 0x48, 0x83, 0xee, 0x01, 0x88, 0x16, 0x48, 0x89, 0xc7, 0x48, 0x85, 0xff, 0x75, 0xe2, 0x48, 0x89, 0xea, 0x48, 0x29, 0xf2, 0x45, 0x84, 0xc0, 0x74, 0x0b, 0x48, 0x83, 0xee, 0x01, 0xc6, 0x06, 0x2d, 0x48, 0x83, 0xc2, 0x01, 0xb8, 0x01, 0x00, 0x00, 0x00, 0xbf, 0x01, 0x00, 0x00, 0x00, 0x0f, 0x05, 0x48, 0x89, 0xec, 0x5d, 0xc3]
    @g.pi_off = _code_len(@g)
    @i = 0
    while @i < 122
        _eb(@g, @b[@i])
        @i = @i + 1
    return 0


# --- Expression parser (precedence-climbing) -------------------------

fn parse_expr(@g: Gen) -> int
    parse_bor(@g)
    return 0

fn parse_bor(@g: Gen) -> int
    parse_bxor(@g)
    while _peek_kind(@g) == TK_PIPE
        _advance(@g)
        _em_push_rax(@g)
        parse_bxor(@g)
        _em_mov_rcx_rax(@g)
        _em_pop_rax(@g)
        _em_or_rax_rcx(@g)
    return 0

fn parse_bxor(@g: Gen) -> int
    parse_band(@g)
    while _peek_kind(@g) == TK_CARET
        _advance(@g)
        _em_push_rax(@g)
        parse_band(@g)
        _em_mov_rcx_rax(@g)
        _em_pop_rax(@g)
        _em_xor_rax_rcx(@g)
    return 0

fn parse_band(@g: Gen) -> int
    parse_cmp(@g)
    while _peek_kind(@g) == TK_AMP
        _advance(@g)
        _em_push_rax(@g)
        parse_cmp(@g)
        _em_mov_rcx_rax(@g)
        _em_pop_rax(@g)
        _em_and_rax_rcx(@g)
    return 0

fn parse_cmp(@g: Gen) -> int
    parse_shift(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_EQ
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 148)
        elif @k == TK_NEQ
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 149)
        elif @k == TK_LT
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 156)
        elif @k == TK_LE
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 158)
        elif @k == TK_GT
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 159)
        elif @k == TK_GE
            _advance(@g)
            _em_push_rax(@g)
            parse_shift(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_cmp_rax_rcx(@g)
            _em_set_cond(@g, 157)
        else
            break
    return 0

fn parse_shift(@g: Gen) -> int
    parse_add(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_SHL
            _advance(@g)
            _em_push_rax(@g)
            parse_add(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_shl_rax_cl(@g)
        elif @k == TK_SHR
            _advance(@g)
            _em_push_rax(@g)
            parse_add(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_shr_rax_cl(@g)
        else
            break
    return 0

fn parse_add(@g: Gen) -> int
    parse_mul(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_PLUS
            _advance(@g)
            _em_push_rax(@g)
            parse_mul(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_add_rax_rcx(@g)
        elif @k == TK_MINUS
            _advance(@g)
            _em_push_rax(@g)
            parse_mul(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_sub_rax_rcx(@g)
        else
            break
    return 0

fn parse_mul(@g: Gen) -> int
    parse_unary(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_STAR
            _advance(@g)
            _em_push_rax(@g)
            parse_unary(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_imul_rax_rcx(@g)
        elif @k == TK_SLASH
            _advance(@g)
            _em_push_rax(@g)
            parse_unary(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_idiv_rcx(@g)
        elif @k == TK_PERCENT
            _advance(@g)
            _em_push_rax(@g)
            parse_unary(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _em_idiv_rcx(@g)
            _em_mov_rax_rdx(@g)
        else
            break
    return 0

# Emit cast of rax to target primitive type (mask or sign-extend).
fn _emit_cast(@g: Gen, @tname: int) -> int
    if str_eq(@tname, "u8") == 1
        # and rax, 0xff
        _eb(@g, 72)
        _eb(@g, 37)                          # 48 25 <imm32>
        _e32(@g, 255)
        return 0
    if str_eq(@tname, "bool") == 1
        # !!x: non-zero becomes 1.  cmp rax, 0; setne al; movzx rax, al
        _eb(@g, 72)
        _eb(@g, 131)
        _eb(@g, 248)
        _eb(@g, 0)                           # 48 83 f8 00  cmp rax, 0
        _em_set_cond(@g, 149)                # setne
        return 0
    if str_eq(@tname, "u16") == 1
        _eb(@g, 72)
        _eb(@g, 37)
        _e32(@g, 65535)
        return 0
    if str_eq(@tname, "u32") == 1
        # mov eax, eax — zeroes top 32 bits.
        _eb(@g, 137)
        _eb(@g, 192)                         # 89 c0
        return 0
    if str_eq(@tname, "i8") == 1
        # movsx rax, al  ; 48 0f be c0
        _eb(@g, 72)
        _eb(@g, 15)
        _eb(@g, 190)
        _eb(@g, 192)
        return 0
    if str_eq(@tname, "i16") == 1
        # movsx rax, ax  ; 48 0f bf c0
        _eb(@g, 72)
        _eb(@g, 15)
        _eb(@g, 191)
        _eb(@g, 192)
        return 0
    if str_eq(@tname, "i32") == 1
        # movsxd rax, eax  ; 48 63 c0
        _eb(@g, 72)
        _eb(@g, 99)
        _eb(@g, 192)
        return 0
    # Default (u64 / i64 / usize / isize / pointer / struct) — no-op.
    return 0

fn parse_unary(@g: Gen) -> int
    if _peek_kind(@g) == TK_MINUS
        _advance(@g)
        parse_unary(@g)
        _em_neg_rax(@g)
        return _parse_cast_suffix(@g)
    if _peek_kind(@g) == TK_TILDE
        _advance(@g)
        parse_unary(@g)
        _em_not_rax(@g)
        return _parse_cast_suffix(@g)
    # Address-of a local (or one of its fields): &@name[.field]?
    #   &@x           → lea rax, [rbp + local_off]  (pointer to stack slot)
    #   &@obj.field   → load @obj into rax, then `add rax, field_off`
    if _peek_kind(@g) == TK_AMP
        if vec_get(@g.kind, @g.pos + 1) == TK_ATIDENT
            _advance(@g)
            @name = _tok_substr(@g, @g.pos)
            _advance(@g)
            if _peek_kind(@g) == TK_DOT
                # &@obj.field — emit load of obj (heap ptr) + field offset.
                _advance(@g)
                if _peek_kind(@g) != TK_IDENT
                    _die(@g, "expected field name after '&@obj.'")
                    return 0
                @fname = _tok_substr(@g, @g.pos)
                _advance(@g)
                @off = _local_slot(@g, @name)
                _em_load_rbp(@g, @off)          # rax = obj pointer
                @tname = _local_type(@g, @name)
                @field_off = 0
                if str_eq(@tname, "") == 0
                    @s_idx = _struct_lookup(@g, @tname)
                    if @s_idx >= 0
                        @fi = _field_index(@g, @s_idx, @fname)
                        if @fi >= 0
                            @field_off = @fi * 8
                if @field_off != 0
                    # add rax, field_off ; 48 05 <imm32>
                    _eb(@g, 72)
                    _eb(@g, 5)
                    _e32(@g, @field_off)
                return _parse_cast_suffix(@g)
            # Plain &@name → address of stack slot.
            @off = _local_slot(@g, @name)
            _eb(@g, 72)
            _eb(@g, 141)
            _eb(@g, 133)
            _e32(@g, @off)
            return _parse_cast_suffix(@g)
    # Dereference: *expr
    if _peek_kind(@g) == TK_STAR
        _advance(@g)
        parse_unary(@g)
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 0)
        return _parse_cast_suffix(@g)
    parse_primary(@g)
    return _parse_cast_suffix(@g)

# After any primary, consume chained `as T` postfixes.
fn _parse_cast_suffix(@g: Gen) -> int
    while _peek_kind(@g) == TK_KW_AS
        _advance(@g)
        @tname = _parse_type(@g)
        _emit_cast(@g, @tname)
    return 0

fn parse_primary(@g: Gen) -> int
    @k = _peek_kind(@g)
    # Lambda expression: `fn(params) -> T body`. Record the token
    # position and synth name, skip the whole `fn(...) \n INDENT...DEDENT`
    # span (noting captures along the way), and emit either a fnptr-load
    # (no captures) or a heap block {fn_ptr, cap0, cap1, ...} that acts
    # as the closure value. The body is re-parsed and emitted as a
    # synthetic top-level fn after parse_program completes — see
    # _emit_deferred_lambdas / _parse_lambda_body.
    if @k == TK_FN
        @lam_start = @g.pos
        @lam_idx = vec_len(@g.lambda_names)
        @synth = str_concat("__lambda_", int_to_str(@lam_idx))
        _advance(@g)                          # consume 'fn'
        _swallow_generic_params(@g)
        _expect(@g, TK_LPAREN, "expected '(' in lambda params")
        # Collect lambda's own parameter names at depth 1 so we can tell
        # them apart from captures when scanning the body.
        @lam_params = vec_new()
        @pdepth = 1
        while @pdepth > 0
            @ptk = _peek_kind(@g)
            if @ptk == TK_LPAREN
                @pdepth = @pdepth + 1
            elif @ptk == TK_RPAREN
                @pdepth = @pdepth - 1
                if @pdepth == 0
                    _advance(@g)
                    break
            elif @ptk == TK_ATIDENT
                if @pdepth == 1
                    vec_push(@lam_params, _tok_substr(@g, @g.pos))
            elif @ptk == TK_EOF
                break
            _advance(@g)
        if _peek_kind(@g) == TK_ARROW
            _advance(@g)
            @_lt = _parse_type(@g)
        _expect(@g, TK_NEWLINE, "newline after lambda signature")
        _expect(@g, TK_INDENT, "indented lambda body")
        @lam_captures = vec_new()
        @bdepth = 1
        while @bdepth > 0
            @btk = _peek_kind(@g)
            if @btk == TK_INDENT
                @bdepth = @bdepth + 1
            elif @btk == TK_DEDENT
                @bdepth = @bdepth - 1
                if @bdepth == 0
                    _advance(@g)
                    break
            elif @btk == TK_ATIDENT
                @refname = _tok_substr(@g, @g.pos)
                # Not a capture if it's one of the lambda's own params.
                @is_param = 0
                @ppi = 0
                @ppn = vec_len(@lam_params)
                while @ppi < @ppn
                    if str_eq(vec_get(@lam_params, @ppi), @refname) == 1
                        @is_param = 1
                        break
                    @ppi = @ppi + 1
                if @is_param == 0
                    # Capture only when the name binds to a local in the
                    # enclosing fn's current scope.
                    @is_outer = 0
                    @on = vec_len(@g.names)
                    @oi = 0
                    while @oi < @on
                        if str_eq(vec_get(@g.names, @oi), @refname) == 1
                            @is_outer = 1
                            break
                        @oi = @oi + 1
                    if @is_outer == 1
                        @exists = 0
                        @cci = 0
                        @ccn = vec_len(@lam_captures)
                        while @cci < @ccn
                            if str_eq(vec_get(@lam_captures, @cci), @refname) == 1
                                @exists = 1
                                break
                            @cci = @cci + 1
                        if @exists == 0
                            vec_push(@lam_captures, @refname)
            elif @btk == TK_EOF
                break
            _advance(@g)
        vec_push(@g.lambda_names,    @synth)
        vec_push(@g.lambda_starts,   @lam_start)
        vec_push(@g.lambda_captures, @lam_captures)
        @ncaps = vec_len(@lam_captures)
        if @ncaps == 0
            # No captures → bare fn pointer, same as M11b.
            @lph = _em_fnptr_load_placeholder(@g)
            vec_push(@g.fn_patches, @lph)
            vec_push(@g.fn_patches, @synth)
            return 0
        # Build closure block: new_arr(1 + ncaps), then write fn_ptr at
        # [0] and each captured outer value at [1+i]. Save block ptr on
        # the stack across fills so rax is free for intermediate loads.
        _em_mov_eax_imm(@g, @ncaps + 1)
        _inline_new_arr(@g)                    # rax = block ptr
        _em_push_rax(@g)                       # save block ptr
        @lph2 = _em_fnptr_load_placeholder(@g) # rax = fn_ptr
        vec_push(@g.fn_patches, @lph2)
        vec_push(@g.fn_patches, @synth)
        # mov rcx, [rsp]  (peek block ptr)
        _eb(@g, 72)
        _eb(@g, 139)
        _eb(@g, 12)
        _eb(@g, 36)
        # mov [rcx + 0], rax
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 1)
        @cii = 0
        while @cii < @ncaps
            @cname = vec_get(@lam_captures, @cii)
            @coff = _local_slot(@g, @cname)
            _em_load_rbp(@g, @coff)            # rax = captured value
            # mov rcx, [rsp]
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 12)
            _eb(@g, 36)
            # mov [rcx + 8*(1+cii)], rax ; 48 89 81 <disp32>
            _eb(@g, 72)
            _eb(@g, 137)
            _eb(@g, 129)
            _e32(@g, (1 + @cii) * 8)
            @cii = @cii + 1
        _em_pop_rax(@g)                        # rax = block ptr (result)
        return 0
    if @k == TK_INT
        @v = _peek_iv(@g)
        _advance(@g)
        # mov eax, imm32 zero-extends: safe only for positive values
        # that fit in unsigned 32-bit. Fall back to mov rax, imm64.
        if @v >= 0
            if @v < 2147483648
                _em_mov_eax_imm(@g, @v)
                return 0
        _em_mov_rax_imm64(@g, @v)
        return 0
    if @k == TK_STR
        @str_ptr = _peek_iv(@g)
        _advance(@g)
        # Store the literal with an 8-byte length prefix so runtime
        # str_len([ptr-8]) works.
        @data_off = _data_add_luna_str(@g, @str_ptr)
        @lea_at = _em_lea_rax_rip_ph(@g)
        vec_push(@g.str_patches, @lea_at)
        vec_push(@g.str_patches, @data_off)
        return 0
    if @k == TK_FLOAT
        # Parse the source span "DDD.FFF[eS?EEE]" into mantissa + decimal
        # exponent (= fraction_digits + literal_exponent, with sign).
        @s = vec_get(@g.start, @g.pos)
        @l = vec_get(@g.tlen,  @g.pos)
        _advance(@g)
        @span = str_substr(@g.src, @s, @l)
        @slen = str_len(@span)
        @mantissa = 0
        @frac_digits = 0
        @seen_dot = 0
        @exp_val = 0
        @exp_neg = 0
        @i = 0
        while @i < @slen
            @c = str_byte(@span, @i)
            if @c == 46
                @seen_dot = 1
                @i = @i + 1
                continue
            if @c == 95
                @i = @i + 1
                continue
            if @c == 101
                @i = @i + 1
                break
            if @c == 69
                @i = @i + 1
                break
            if @c >= 48
                if @c <= 57
                    @mantissa = @mantissa * 10 + (@c - 48)
                    if @seen_dot == 1
                        @frac_digits = @frac_digits + 1
                    @i = @i + 1
                    continue
            @i = @i + 1
        if @i < @slen
            @se = str_byte(@span, @i)
            if @se == 43
                @i = @i + 1
            elif @se == 45
                @exp_neg = 1
                @i = @i + 1
            while @i < @slen
                @c2 = str_byte(@span, @i)
                if @c2 >= 48
                    if @c2 <= 57
                        @exp_val = @exp_val * 10 + (@c2 - 48)
                @i = @i + 1
            if @exp_neg == 1
                @exp_val = 0 - @exp_val
        @total_exp = @exp_val - @frac_digits
        # Emit: rax = mantissa (int) → cvtsi2sd xmm0 → adjust by 10^total_exp.
        if @mantissa >= 0
            if @mantissa < 2147483648
                _em_mov_eax_imm(@g, @mantissa)
            else
                _em_mov_rax_imm64(@g, @mantissa)
        else
            _em_mov_rax_imm64(@g, @mantissa)
        # cvtsi2sd xmm0, rax  ; f2 48 0f 2a c0
        _eb(@g, 242)
        _eb(@g, 72)
        _eb(@g, 15)
        _eb(@g, 42)
        _eb(@g, 192)
        # Adjust by repeated *10 or /10 per total_exp magnitude.
        @abs_exp = @total_exp
        if @abs_exp < 0
            @abs_exp = 0 - @abs_exp
        if @abs_exp > 0
            # Load constant 10.0 into xmm1 once via rcx.
            _em_mov_rax_imm64(@g, 4621819117588971520)     # 0x4024000000000000 = 10.0
            # movq xmm1, rax ; 66 48 0f 6e c8
            _eb(@g, 102)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 110)
            _eb(@g, 200)
            @k2 = 0
            while @k2 < @abs_exp
                if @total_exp >= 0
                    # mulsd xmm0, xmm1 ; f2 0f 59 c1
                    _eb(@g, 242)
                    _eb(@g, 15)
                    _eb(@g, 89)
                    _eb(@g, 193)
                else
                    # divsd xmm0, xmm1 ; f2 0f 5e c1
                    _eb(@g, 242)
                    _eb(@g, 15)
                    _eb(@g, 94)
                    _eb(@g, 193)
                @k2 = @k2 + 1
        # movq rax, xmm0  ; 66 48 0f 7e c0
        _eb(@g, 102)
        _eb(@g, 72)
        _eb(@g, 15)
        _eb(@g, 126)
        _eb(@g, 192)
        return 0
    if @k == TK_ATIDENT
        @name = _tok_substr(@g, @g.pos)
        _advance(@g)
        @off = _local_slot(@g, @name)
        _em_load_rbp(@g, @off)
        # Closure-call: @f annotated `let @f: closure` holds a pointer
        # to a heap block {fn_ptr, cap0, cap1, ...}. Pass the block
        # itself as rdi (hidden env), user args in rsi..r9 (up to 5),
        # then call [rax + 0].
        if _peek_kind(@g) == TK_LPAREN
            @cl_type = _local_type(@g, @name)
            if str_eq(@cl_type, "closure") == 1
                _advance(@g)
                _em_push_rax(@g)                     # save env (block ptr)
                _eb(@g, 72)
                _eb(@g, 129)
                _eb(@g, 236)
                @cl_sub_at = _code_len(@g)
                _e32(@g, 0)                          # sub rsp, <alloc>
                @cnargs = 0
                if _peek_kind(@g) != TK_RPAREN
                    parse_expr(@g)
                    _eb(@g, 72)
                    _eb(@g, 137)
                    _eb(@g, 4)
                    _eb(@g, 36)                      # mov [rsp], rax
                    @cnargs = 1
                    while _peek_kind(@g) == TK_COMMA
                        _advance(@g)
                        parse_expr(@g)
                        _eb(@g, 72)
                        _eb(@g, 137)
                        _eb(@g, 132)
                        _eb(@g, 36)
                        _e32(@g, @cnargs * 8)        # mov [rsp+i*8], rax
                        @cnargs = @cnargs + 1
                _expect(@g, TK_RPAREN, "expected ')' after closure args")
                @calloc = @cnargs * 8
                if (@calloc % 16) == 0
                    @calloc = @calloc + 8
                _patch32(@g, @cl_sub_at, @calloc)
                # Load user args into argreg[1..5] (env takes argreg[0]).
                @clreg = @cnargs
                if @clreg > 5
                    @clreg = 5
                @cli = 0
                while @cli < @clreg
                    _em_load_argreg_stack(@g, @cli + 1, @cli * 8)
                    @cli = @cli + 1
                # add rsp, calloc
                _eb(@g, 72)
                _eb(@g, 129)
                _eb(@g, 196)
                _e32(@g, @calloc)
                # pop rdi (env = block ptr)  ; 5F
                _eb(@g, 95)
                # mov rax, [rdi]  ; 48 8b 07
                _eb(@g, 72)
                _eb(@g, 139)
                _eb(@g, 7)
                _em_call_rax(@g)
                return 0
        # Indirect call through fn pointer: @f(args)
        # @f's value is already in rax; push it so arg-evaluation can
        # clobber rax, then pop back into rax right before `call rax`.
        # Supports up to 6 args (stack-arg support not needed yet).
        if _peek_kind(@g) == TK_LPAREN
            _advance(@g)
            _em_push_rax(@g)                      # save callee
            # sub rsp, <alloc> — alloc is patched to (nargs*8 aligned so
            # that rsp stays mod 16 = 8 at call time, matching SysV).
            _eb(@g, 72)
            _eb(@g, 129)
            _eb(@g, 236)
            @sub_imm_at = _code_len(@g)
            _e32(@g, 0)
            @inargs = 0
            if _peek_kind(@g) != TK_RPAREN
                parse_expr(@g)
                _eb(@g, 72)
                _eb(@g, 137)
                _eb(@g, 4)
                _eb(@g, 36)                       # mov [rsp], rax
                @inargs = 1
                while _peek_kind(@g) == TK_COMMA
                    _advance(@g)
                    parse_expr(@g)
                    _eb(@g, 72)
                    _eb(@g, 137)
                    _eb(@g, 132)
                    _eb(@g, 36)
                    _e32(@g, @inargs * 8)        # mov [rsp+i*8], rax
                    @inargs = @inargs + 1
            _expect(@g, TK_RPAREN, "expected ')' after indirect call args")
            @ialloc = @inargs * 8
            # Callee was pushed (8 bytes), so total shift is ialloc+8. We
            # want that %16 == 0 ⇒ ialloc %16 == 8 ⇒ if ialloc %16 == 0,
            # pad with 8.
            if (@ialloc % 16) == 0
                @ialloc = @ialloc + 8
            _patch32(@g, @sub_imm_at, @ialloc)
            # Load arg regs from stack slots (indirect calls limited to 6 args).
            @inreg = @inargs
            if @inreg > 6
                @inreg = 6
            @ii = 0
            while @ii < @inreg
                _em_load_argreg_stack(@g, @ii, @ii * 8)
                @ii = @ii + 1
            # Restore stack to the point right above the saved callee.
            _eb(@g, 72)
            _eb(@g, 129)
            _eb(@g, 196)
            _e32(@g, @ialloc)                    # add rsp, ialloc
            _em_pop_rax(@g)                      # rax = callee
            _em_call_rax(@g)
            return 0
        # Array index read: @arr[i]
        if _peek_kind(@g) == TK_LBRACK
            _advance(@g)
            _em_push_rax(@g)
            parse_expr(@g)
            _expect(@g, TK_RBRACK, "expected ']'")
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 4)
            _eb(@g, 200)
            return 0
        # Struct field read: @obj.field
        if _peek_kind(@g) == TK_DOT
            _advance(@g)
            if _peek_kind(@g) != TK_IDENT
                _die(@g, "expected field name after '.'")
                return 0
            @fname = _tok_substr(@g, @g.pos)
            _advance(@g)
            @tname = _local_type(@g, @name)
            @field_off = 0
            if str_eq(@tname, "") == 0
                @s_idx = _struct_lookup(@g, @tname)
                if @s_idx >= 0
                    @fi = _field_index(@g, @s_idx, @fname)
                    if @fi >= 0
                        @field_off = @fi * 8
            # mov rax, [rax + field_off]
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 128)
            _e32(@g, @field_off)
            return 0
        return 0
    # Variant constructor: VariantName  or  VariantName(expr)
    # Emits a 16-byte enum value: [tag: u64][payload: u64].
    if @k == TK_IDENT
        @vname_chk = _tok_substr(@g, @g.pos)
        @vi = _variant_index(@g, @vname_chk)
        if @vi >= 0
            _advance(@g)
            # Swallow `Some<int>(42)` style type args.
            _swallow_generic_params(@g)
            @tag  = vec_get(@g.variant_tag,     @vi)
            @hasp = vec_get(@g.variant_payload, @vi)
            # Evaluate payload first (if any) and save it. Otherwise
            # use 0 as payload.
            if @hasp == 1
                _expect(@g, TK_LPAREN, "expected '(' for variant payload")
                parse_expr(@g)
                _expect(@g, TK_RPAREN, "expected ')' after variant payload")
                _em_push_rax(@g)
            else
                # Allow the optional-paren form `None()` too, but treat
                # an absent-paren as zero-arg. We don't consume any ( ).
                _em_mov_eax_imm(@g, 0)
                _em_push_rax(@g)
            # Allocate 2-slot heap block for {tag, payload}.
            _em_mov_eax_imm(@g, 2)
            _inline_new_arr(@g)               # rax = new ptr
            # mov r8, rax                     ; r8 = enum ptr
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 192)
            # Pop payload → [r8 + 8]
            _em_pop_rax(@g)
            # mov [r8 + 8], rax ; 49 89 40 08
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 64)
            _eb(@g, 8)
            # Write tag immediate into [r8 + 0]. Use an r8-relative
            # store with imm32: 49 c7 00 <imm32>.
            _eb(@g, 73)
            _eb(@g, 199)
            _eb(@g, 0)
            _e32(@g, @tag)
            # rax = r8
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 192)
            return 0
    # Struct literal: Name { field1: v1, field2: v2, ... }
    if @k == TK_IDENT
        # Look ahead: is this `Name {`? Distinguish from fn call `name(`
        @name = _tok_substr(@g, @g.pos)
        @s_idx = _struct_lookup(@g, @name)
        if @s_idx >= 0
            _advance(@g)
            # Swallow optional generic args `Pair<A, B> { ... }`.
            _swallow_generic_params(@g)
            if _peek_kind(@g) == TK_LBRACE
                _advance(@g)
                @fields = vec_get(@g.struct_fields, @s_idx)
                @nfields = vec_len(@fields)
                # Parse field inits in any order; track seen offsets.
                # For simplicity, we require they come in the same order
                # as the struct decl. Stack them, then alloc + fill.
                @count = 0
                while _peek_kind(@g) != TK_RBRACE
                    if _peek_kind(@g) != TK_IDENT
                        _die(@g, "expected field name in struct lit")
                        return 0
                    _advance(@g)                  # consume name
                    _expect(@g, TK_COLON, "expected ':' in struct lit")
                    parse_expr(@g)
                    _em_push_rax(@g)
                    @count = @count + 1
                    if _peek_kind(@g) == TK_COMMA
                        _advance(@g)
                    elif _peek_kind(@g) == TK_NEWLINE
                        _skip_newlines(@g)
                _expect(@g, TK_RBRACE, "expected '}' after struct lit")
                # Allocate struct as N-slot array.
                _em_mov_eax_imm(@g, @nfields)
                _inline_new_arr(@g)                # rax = struct ptr
                # mov r8, rax
                _eb(@g, 73)
                _eb(@g, 137)
                _eb(@g, 192)
                # Pop values into fields in reverse push order.
                @i = @count - 1
                while @i >= 0
                    _em_pop_rax(@g)               # rax = last-pushed value
                    # mov [r8 + i*8], rax  ; 49 89 80 <disp32>
                    _eb(@g, 73)
                    _eb(@g, 137)
                    _eb(@g, 128)
                    _e32(@g, @i * 8)
                    @i = @i - 1
                # rax = r8
                _eb(@g, 76)
                _eb(@g, 137)
                _eb(@g, 192)
                return 0
            # Not a struct literal — fall through to function-call path.
            # But we already advanced past the ident; un-advance by rewinding.
            @g.pos = @g.pos - 1
    if @k == TK_LBRACK
        _advance(@g)
        # Two forms:
        #   [v; N]       repeat form
        #   [a, b, c]    list form (possibly empty)
        if _peek_kind(@g) == TK_RBRACK
            _advance(@g)
            # empty array: new_arr(0) — inline
            _em_mov_eax_imm(@g, 0)
            _inline_new_arr(@g)
            return 0
        # Parse first element
        parse_expr(@g)
        if _peek_kind(@g) == TK_SEMI
            _advance(@g)
            _em_push_rax(@g)                 # save value
            parse_expr(@g)                   # rax = count
            _expect(@g, TK_RBRACK, "expected ']'")
            # Allocate array, then fill with value in a loop.
            # Keep count on stack for loop; rax = count will be used for alloc.
            _em_push_rax(@g)                 # push count
            _inline_new_arr(@g)              # rax = arr_ptr
            _em_push_rax(@g)                 # push arr
            # Now stack: [arr, count, value] top-to-bottom
            # Fill loop: for i = 0 to count-1: arr[i] = value
            # Pseudo: counter in r11, value in r10
            # Load: pop arr; pop count; pop value → but we need them in order
            # Actually reorganize. Stack top = arr, next = count, next = value.
            _em_pop_rax(@g)                  # rax = arr
            _eb(@g, 73)                      # mov r8, rax (arr base)
            _eb(@g, 137)
            _eb(@g, 192)
            _em_pop_rax(@g)                  # rax = count
            _eb(@g, 73)                      # mov r9, rax (count)
            _eb(@g, 137)
            _eb(@g, 193)
            _em_pop_rax(@g)                  # rax = value
            _eb(@g, 73)                      # mov r10, rax (value)
            _eb(@g, 137)
            _eb(@g, 194)
            # rcx = 0 (loop counter)
            _eb(@g, 185)                     # mov ecx, 0
            _e32(@g, 0)
            # loop_top:
            @loop_top = _code_len(@g)
            # cmp rcx, r9 ; 4c 39 c9
            _eb(@g, 76)
            _eb(@g, 57)
            _eb(@g, 201)
            # jge end (jnl) ; 7d rel8 — use jz_placeholder pattern
            # Use jge rel32 = 0f 8d <rel32>
            _eb(@g, 15)
            _eb(@g, 141)
            @jge_at = _code_len(@g)
            _e32(@g, 0)
            # mov [r8 + rcx*8], r10 ; 4d 89 14 c8
            _eb(@g, 77)
            _eb(@g, 137)
            _eb(@g, 20)
            _eb(@g, 200)
            # inc rcx ; 48 ff c1
            _eb(@g, 72)
            _eb(@g, 255)
            _eb(@g, 193)
            # jmp loop_top
            _em_jmp_to(@g, @loop_top)
            _patch_here(@g, @jge_at)
            # rax = r8 (array base)
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 192)                     # mov rax, r8
            return 0
        # List form: push first, then parse the rest
        _em_push_rax(@g)
        @n = 1
        while _peek_kind(@g) == TK_COMMA
            _advance(@g)
            if _peek_kind(@g) == TK_RBRACK
                break
            parse_expr(@g)
            _em_push_rax(@g)
            @n = @n + 1
        _expect(@g, TK_RBRACK, "expected ']'")
        # Allocate array: rax = N, then inline new_arr
        _em_mov_eax_imm(@g, @n)
        _inline_new_arr(@g)                   # rax = arr ptr
        # Store pushed values into arr[n-1], arr[n-2], ..., arr[0]
        # Stack top has the last-pushed = elem_{n-1}. Pop order matches i=n-1 down.
        _eb(@g, 73)                           # mov r8, rax (arr base)
        _eb(@g, 137)
        _eb(@g, 192)
        @i = @n - 1
        while @i >= 0
            _em_pop_rax(@g)                   # rax = elem_i (from top of stack)
            # mov [r8 + i*8], rax ; 49 89 80 <disp32>
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 128)
            _e32(@g, @i * 8)
            @i = @i - 1
        # rax = r8 (array base)
        _eb(@g, 76)
        _eb(@g, 137)
        _eb(@g, 192)
        return 0
    if @k == TK_LPAREN
        _advance(@g)
        parse_expr(@g)
        _expect(@g, TK_RPAREN, "expected ')'")
        return 0
    # Function-call expression: `name(arg1, arg2, ...)`
    if @k == TK_IDENT
        @name = _tok_substr(@g, @g.pos)
        # Constant reference: if name is a known module-level const, emit
        # its value as an immediate and advance.
        @cout = vec_new()
        if _const_lookup(@g, @name, @cout) == 1
            _advance(@g)
            @cv = vec_get(@cout, 0)
            if @cv >= 0
                if @cv < 2147483648
                    _em_mov_eax_imm(@g, @cv)
                    return 0
            _em_mov_rax_imm64(@g, @cv)
            return 0
        # Fn pointer value: bare fn name not followed by `(` or `<` (a
        # generic arg list leads into a call). Emits `mov rax, [rip+disp32]`
        # pulling the current fn address from its hot-swap slot, so indirect
        # calls through the pointer still honour live patches.
        if _fn_name_index(@g, @name) >= 0
            @fp_nxt = vec_get(@g.kind, @g.pos + 1)
            if @fp_nxt != TK_LPAREN
                if @fp_nxt != TK_LT
                    _advance(@g)
                    @fph = _em_fnptr_load_placeholder(@g)
                    vec_push(@g.fn_patches, @fph)
                    vec_push(@g.fn_patches, @name)
                    return 0
        # shine_int is parsed as a call but emits inline code via helper.
        if str_eq(@name, "shine_int") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after shine_int")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _em_mov_rdi_rax(@g)
            _em_call_to(@g, @g.pi_off)
            return 0
        # str_len(s) — inline: rax = ptr, then rax = [rax - 8]
        if str_eq(@name, "str_len") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after str_len")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov rax, [rax - 8]  ; 48 8b 40 f8
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 64)
            _eb(@g, 248)
            return 0
        # str_byte(s, i) — inline: rax = s, rcx = i, rax = byte at [s + i]
        if str_eq(@name, "str_byte") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after str_byte")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ',' in str_byte")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)           # rcx = i
            _em_pop_rax(@g)               # rax = s
            _expect(@g, TK_RPAREN, "expected ')'")
            # movzx rax, byte [rax + rcx]  ; 48 0f b6 04 08
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 182)
            _eb(@g, 4)
            _eb(@g, 8)
            return 0
        # new_str(n) — bump allocate from heap_top; returns pointer past
        # the 8-byte length prefix. Inlines ~37 bytes of x86-64.
        if str_eq(@name, "new_str") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after new_str")
            parse_expr(@g)                # rax = n (requested length)
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov rcx, rax                ; save n
            _eb(@g, 72)
            _eb(@g, 137)
            _eb(@g, 193)
            # add rax, 16
            _eb(@g, 72)
            _eb(@g, 131)
            _eb(@g, 192)
            _eb(@g, 16)
            # and rax, -8                  ; rax = aligned alloc size
            _eb(@g, 72)
            _eb(@g, 131)
            _eb(@g, 224)
            _eb(@g, 248)
            # mov r11, rax                 ; r11 = alloc size
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 195)
            # lea rax, [rip + heap_top_disp32]  ; patched later
            _eb(@g, 72)
            _eb(@g, 141)
            _eb(@g, 5)
            @lea_at = _code_len(@g)
            _e32(@g, 0)
            vec_push(@g.heap_patches, @lea_at)
            # mov rsi, [rax]               ; rsi = current heap_top
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 48)
            # add r11, rsi                 ; r11 = new heap_top
            _eb(@g, 73)
            _eb(@g, 1)
            _eb(@g, 243)
            # mov [rax], r11               ; store new heap_top
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 24)
            # mov [rsi], rcx               ; write length prefix at old top
            _eb(@g, 72)
            _eb(@g, 137)
            _eb(@g, 14)
            # lea rax, [rsi + 8]           ; return pointer
            _eb(@g, 72)
            _eb(@g, 141)
            _eb(@g, 70)
            _eb(@g, 8)
            return 0
        # Linux syscall intrinsics. Each evaluates args left-to-right,
        # pushes, then pops into the syscall argument registers before
        # setting rax to the syscall number and emitting `syscall`.
        #
        # The Linux syscall ABI for integer args: rdi, rsi, rdx, r10,
        # r8, r9 — slightly different from SysV (r10 instead of rcx).
        if str_eq(@name, "sys_read") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 0)
            return 0
        if str_eq(@name, "sys_write") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 1)
            return 0
        if str_eq(@name, "sys_open") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 2)
            return 0
        if str_eq(@name, "sys_close") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 1, 3)
            return 0
        if str_eq(@name, "sys_lseek") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 8)
            return 0
        if str_eq(@name, "sys_exit") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 1, 60)
            return 0
        if str_eq(@name, "sys_creat") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 2, 85)
            return 0
        # mmap(addr, len, prot, flags, fd, offset) — 6 args, syscall 9
        if str_eq(@name, "sys_mmap") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 6, 9)
            return 0
        if str_eq(@name, "sys_munmap") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 2, 11)
            return 0
        if str_eq(@name, "sys_brk") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 1, 12)
            return 0
        if str_eq(@name, "sys_getpid") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 0, 39)
            return 0
        if str_eq(@name, "sys_getrandom") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 318)
            return 0
        # --- Socket / memory-protect syscalls (for hot-swap listener) ---
        if str_eq(@name, "sys_socket") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 41)
            return 0
        if str_eq(@name, "sys_bind") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 49)
            return 0
        if str_eq(@name, "sys_listen") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 2, 50)
            return 0
        if str_eq(@name, "sys_accept") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 43)
            return 0
        if str_eq(@name, "sys_connect") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 42)
            return 0
        if str_eq(@name, "sys_mprotect") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 10)
            return 0
        if str_eq(@name, "sys_nanosleep") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 2, 35)
            return 0
        # Threading primitives. sys_clone: raw clone(2). Beware that the
        # child resumes at the instruction right after the syscall and
        # that its rsp is the caller-supplied stack — using thread_spawn
        # is almost always what you want instead.
        if str_eq(@name, "sys_clone") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 5, 56)
            return 0
        if str_eq(@name, "sys_futex") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 6, 202)
            return 0
        if str_eq(@name, "sys_gettid") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 0, 186)
            return 0
        if str_eq(@name, "sys_tgkill") == 1
            _advance(@g)
            _emit_syscall_intrinsic(@g, 3, 234)
            return 0
        # thread_spawn(fn_ptr, arg) -> tid
        # Compound intrinsic: mmaps a 64 KB child stack, plants (fn, arg)
        # at its top, clones with CLONE_VM | CLONE_THREAD | ... so the
        # child shares the address space and signal handlers, and on the
        # child side calls fn(arg) and exits. Parent returns the tid.
        #
        # NB: the bump heap is not lock-free yet — allocating from
        # multiple threads concurrently races. Either have the child do
        # all its allocation before the parent re-enters an allocating
        # path, or guard new_arr calls with sys_futex.
        if str_eq(@name, "thread_spawn") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after thread_spawn")
            parse_expr(@g)                       # rax = fn_ptr
            _em_push_rax(@g)                     # [rsp+8] = fn_ptr (after next push)
            _expect(@g, TK_COMMA, "expected ',' in thread_spawn")
            parse_expr(@g)                       # rax = arg
            _em_push_rax(@g)                     # [rsp] = arg
            _expect(@g, TK_RPAREN, "expected ')' after thread_spawn")
            # mmap(NULL, 65536, PROT_RW, MAP_PRIVATE|MAP_ANON, -1, 0)
            _eb(@g, 49)
            _eb(@g, 255)                         # xor edi, edi
            _eb(@g, 190)                         # mov esi, imm32
            _e32(@g, 65536)
            _eb(@g, 186)                         # mov edx, imm32
            _e32(@g, 3)
            _eb(@g, 65)
            _eb(@g, 186)                         # mov r10d, imm32
            _e32(@g, 34)                         # 0x22 MAP_PRIVATE|MAP_ANON
            _eb(@g, 73)
            _eb(@g, 199)
            _eb(@g, 192)                         # mov r8, imm32 (sign-ext)
            _e32(@g, 0 - 1)                      # -1 (fd)
            _eb(@g, 69)
            _eb(@g, 49)
            _eb(@g, 201)                         # xor r9d, r9d
            _eb(@g, 184)                         # mov eax, imm32
            _e32(@g, 9)                          # sys_mmap
            _em_syscall(@g)
            # r13 = rax + 65520  (top-16 stays 16-aligned)
            _eb(@g, 76)
            _eb(@g, 141)
            _eb(@g, 168)                         # lea r13, [rax + disp32]
            _e32(@g, 65520)
            # pop arg, store at [r13+8]
            _em_pop_rax(@g)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 69)
            _eb(@g, 8)                           # mov [r13+8], rax
            # pop fn_ptr, store at [r13]
            _em_pop_rax(@g)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 69)
            _eb(@g, 0)                           # mov [r13+0], rax
            # clone(0x50f00, r13, 0, 0, 0)
            _eb(@g, 191)                         # mov edi, imm32
            _e32(@g, 330496)                     # 0x50f00 CLONE_VM|FS|FILES|SIGHAND|THREAD|SYSVSEM
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 238)                         # mov rsi, r13
            _eb(@g, 49)
            _eb(@g, 210)                         # xor edx, edx
            _eb(@g, 77)
            _eb(@g, 49)
            _eb(@g, 210)                         # xor r10, r10
            _eb(@g, 69)
            _eb(@g, 49)
            _eb(@g, 192)                         # xor r8d, r8d
            _eb(@g, 184)                         # mov eax, imm32
            _e32(@g, 56)                         # sys_clone
            _em_syscall(@g)
            # test rax, rax ; jnz parent_ret (skip child block, rel32 patched)
            _eb(@g, 72)
            _eb(@g, 133)
            _eb(@g, 192)                         # test rax, rax
            _eb(@g, 15)
            _eb(@g, 133)                         # jnz rel32
            @par_patch = _code_len(@g)
            _e32(@g, 0)
            # Child path — rsp == r13 == child stack top.
            # mov rdi, [rsp+8] ; rax = [rsp] ; call rax ; sys_exit(0)
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 124)
            _eb(@g, 36)
            _eb(@g, 8)                           # mov rdi, [rsp+8]
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 4)
            _eb(@g, 36)                          # mov rax, [rsp]
            _em_call_rax(@g)
            _eb(@g, 49)
            _eb(@g, 255)                         # xor edi, edi
            _eb(@g, 184)                         # mov eax, imm32
            _e32(@g, 60)                         # sys_exit
            _em_syscall(@g)
            # Parent lands here; rax = child tid.
            _patch_here(@g, @par_patch)
            return 0
        # --- Hot-swap metadata accessors ---
        # Each emits `mov rax, qword [rip + disp32]` reading the u64
        # stored at the corresponding data-section metadata offset.
        # The disp32 is patched by main2.luna after layout is known.
        if str_eq(@name, "hot_slots_ptr") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after hot_slots_ptr")
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_hotmeta_load(@g, 8)
            return 0
        if str_eq(@name, "hot_count") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after hot_count")
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_hotmeta_load(@g, 16)
            return 0
        if str_eq(@name, "hot_names_ptr") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after hot_names_ptr")
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_hotmeta_load(@g, 24)
            return 0
        if str_eq(@name, "hot_meta_base") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after hot_meta_base")
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_hotmeta_load(@g, 32)
            return 0
        # --- f64 math (via SSE xmm0/xmm1) ---
        # Inputs/outputs pass through rax as the raw 64-bit bit pattern
        # of the IEEE-754 double. Callers use `f64_lit(0x400921FB...)`
        # for literal constants and `f64_from_int(n)` to convert ints.
        # f64_from_int(n): cvtsi2sd xmm0, rax; movq rax, xmm0
        if str_eq(@name, "f64_from_int") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_from_int")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # cvtsi2sd xmm0, rax  ; f2 48 0f 2a c0
            _eb(@g, 242)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 42)
            _eb(@g, 192)
            # movq rax, xmm0      ; 66 48 0f 7e c0
            _eb(@g, 102)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 126)
            _eb(@g, 192)
            return 0
        # f64_to_int(x): cvttsd2si rax, xmm0  (truncating int conversion)
        if str_eq(@name, "f64_to_int") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_to_int")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # movq xmm0, rax      ; 66 48 0f 6e c0
            _eb(@g, 102)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 110)
            _eb(@g, 192)
            # cvttsd2si rax, xmm0 ; f2 48 0f 2c c0
            _eb(@g, 242)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 44)
            _eb(@g, 192)
            return 0
        # f64_lit(bits): no-op — caller passed the raw u64 bit pattern.
        if str_eq(@name, "f64_lit") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_lit")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            return 0
        # Binary SSE ops: f64_add / sub / mul / div (a, b)
        if str_eq(@name, "f64_add") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_add")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_binop(@g, 88)          # addsd opcode byte (f2 0f 58)
            return 0
        if str_eq(@name, "f64_sub") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_sub")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_binop(@g, 92)          # subsd (f2 0f 5c)
            return 0
        if str_eq(@name, "f64_mul") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_mul")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_binop(@g, 89)          # mulsd (f2 0f 59)
            return 0
        if str_eq(@name, "f64_div") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_div")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_binop(@g, 94)          # divsd (f2 0f 5e)
            return 0
        # f64_sqrt(x): sqrtsd xmm0, xmm0
        if str_eq(@name, "f64_sqrt") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_sqrt")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # movq xmm0, rax  ;  66 48 0f 6e c0
            _eb(@g, 102)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 110)
            _eb(@g, 192)
            # sqrtsd xmm0, xmm0  ; f2 0f 51 c0
            _eb(@g, 242)
            _eb(@g, 15)
            _eb(@g, 81)
            _eb(@g, 192)
            # movq rax, xmm0  ; 66 48 0f 7e c0
            _eb(@g, 102)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 126)
            _eb(@g, 192)
            return 0
        # f64_lt(a, b): ucomisd xmm0(a), xmm1(b) → CF=1 when a<b → setb.
        if str_eq(@name, "f64_lt") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_lt")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_cmp(@g, 146)           # setb (CF=1)
            return 0
        # f64_gt(a, b): CF=0 && ZF=0 when a>b → seta.
        if str_eq(@name, "f64_gt") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_gt")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_cmp(@g, 151)           # seta (CF=0, ZF=0)
            return 0
        if str_eq(@name, "f64_eq") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after f64_eq")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _emit_f64_cmp(@g, 148)           # sete
            return 0
        # u64_get(buf, word_idx) — load 8 bytes at buf + word_idx*8
        if str_eq(@name, "u64_get") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u64_get")
            parse_expr(@g)                   # rax = buf
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                   # rax = idx
            _em_mov_rcx_rax(@g)              # rcx = idx
            _em_pop_rax(@g)                  # rax = buf
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov rax, [rax + rcx*8]   ; 48 8b 04 c8
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 4)
            _eb(@g, 200)
            return 0
        # u64_set(buf, word_idx, val) — store val at buf + word_idx*8
        if str_eq(@name, "u64_set") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u64_set")
            parse_expr(@g)                   # buf
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                   # idx
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                   # val (rax)
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov r8, rax (val)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 192)
            # pop rcx (idx)
            _eb(@g, 89)
            # pop rdx (buf)
            _eb(@g, 90)
            # mov [rdx + rcx*8], r8  ; 4c 89 04 ca
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 4)
            _eb(@g, 202)
            # return 0
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        # --- Byte-level load/store (hacker toolkit, no length prefix) ---
        # u8_at(ptr, off): movzx rax, byte [ptr + off]
        if str_eq(@name, "u8_at") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u8_at")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # movzx rax, byte [rax + rcx]  ; 48 0f b6 04 08
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 182)
            _eb(@g, 4)
            _eb(@g, 8)
            return 0
        # u16_at(ptr, off): movzx rax, word [ptr + off]
        if str_eq(@name, "u16_at") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u16_at")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # movzx rax, word [rax + rcx]  ; 48 0f b7 04 08
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 183)
            _eb(@g, 4)
            _eb(@g, 8)
            return 0
        # u32_at(ptr, off): mov eax, dword [ptr + off]   (zero-extends)
        if str_eq(@name, "u32_at") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u32_at")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov eax, [rax + rcx]  ; 8b 04 08  (REX omitted => 32-bit zero-extends)
            _eb(@g, 139)
            _eb(@g, 4)
            _eb(@g, 8)
            return 0
        # u8_set(ptr, off, v): mov [ptr+off], v_low_byte; return 0
        if str_eq(@name, "u8_set") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u8_set")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov r8, rax (value) ; pop rcx (off) ; pop rdx (ptr)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 192)
            _eb(@g, 89)
            _eb(@g, 90)
            # mov [rdx + rcx], r8b  ; 44 88 04 0a
            _eb(@g, 68)
            _eb(@g, 136)
            _eb(@g, 4)
            _eb(@g, 10)
            _eb(@g, 49)                    # xor eax, eax (return 0)
            _eb(@g, 192)
            return 0
        # u16_set(ptr, off, v): mov [ptr+off], v_word; return 0
        if str_eq(@name, "u16_set") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u16_set")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _eb(@g, 73)                    # mov r8, rax
            _eb(@g, 137)
            _eb(@g, 192)
            _eb(@g, 89)                    # pop rcx
            _eb(@g, 90)                    # pop rdx
            # mov [rdx + rcx], r8w  ; 66 44 89 04 0a  (16-bit operand-size prefix 66)
            _eb(@g, 102)
            _eb(@g, 68)
            _eb(@g, 137)
            _eb(@g, 4)
            _eb(@g, 10)
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        # u32_set(ptr, off, v): mov [ptr+off], v_dword; return 0
        if str_eq(@name, "u32_set") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after u32_set")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _eb(@g, 73)                    # mov r8, rax
            _eb(@g, 137)
            _eb(@g, 192)
            _eb(@g, 89)                    # pop rcx
            _eb(@g, 90)                    # pop rdx
            # mov [rdx + rcx], r8d  ; 44 89 04 0a
            _eb(@g, 68)
            _eb(@g, 137)
            _eb(@g, 4)
            _eb(@g, 10)
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        # --- Bit tricks ---
        # bswap64(x): BSWAP rax (reverses bytes in a 64-bit value)
        if str_eq(@name, "bswap64") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after bswap64")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _eb(@g, 72)                    # 48 0f c8  ; bswap rax
            _eb(@g, 15)
            _eb(@g, 200)
            return 0
        # bswap32(x): BSWAP eax (for 32-bit values, zero-extends to rax)
        if str_eq(@name, "bswap32") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after bswap32")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            _eb(@g, 15)                    # 0f c8  ; bswap eax
            _eb(@g, 200)
            return 0
        # popcount(x): POPCNT rax, rax
        if str_eq(@name, "popcount") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after popcount")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # f3 48 0f b8 c0
            _eb(@g, 243)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 184)
            _eb(@g, 192)
            return 0
        # clz(x): count leading zeros in 64-bit. LZCNT rax, rax.
        if str_eq(@name, "clz") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after clz")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # f3 48 0f bd c0
            _eb(@g, 243)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 189)
            _eb(@g, 192)
            return 0
        # ctz(x): count trailing zeros. TZCNT rax, rax.
        if str_eq(@name, "ctz") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after ctz")
            parse_expr(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # f3 48 0f bc c0
            _eb(@g, 243)
            _eb(@g, 72)
            _eb(@g, 15)
            _eb(@g, 188)
            _eb(@g, 192)
            return 0
        # rotl(x, n): rotate x left by n bits. rcx = n (only low 6 bits used).
        if str_eq(@name, "rotl") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after rotl")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # rol rax, cl  ; 48 d3 c0
            _eb(@g, 72)
            _eb(@g, 211)
            _eb(@g, 192)
            return 0
        # rotr(x, n): rotate right
        if str_eq(@name, "rotr") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after rotr")
            parse_expr(@g)
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)
            _em_mov_rcx_rax(@g)
            _em_pop_rax(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            # ror rax, cl  ; 48 d3 c8
            _eb(@g, 72)
            _eb(@g, 211)
            _eb(@g, 200)
            return 0
        # --- Memory ops ---
        # memcpy(dst, src, n): byte-copy n bytes. dst,src,n ; returns dst.
        if str_eq(@name, "memcpy") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after memcpy")
            parse_expr(@g)                        # dst
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                        # src
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                        # n
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov rcx, rax (n) ; pop rsi (src) ; pop rdi (dst)
            _em_mov_rcx_rax(@g)
            _eb(@g, 94)                           # pop rsi
            _eb(@g, 95)                           # pop rdi
            # rep movsb (f3 a4)
            _eb(@g, 243)
            _eb(@g, 164)
            # mov rax, rdi (return dst — but rdi has advanced, so reload from saved copy)
            # For simplicity return 0. Callers who want dst keep it themselves.
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        # memset(ptr, byte, n): fill n bytes with byte. Returns 0.
        if str_eq(@name, "memset") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after memset")
            parse_expr(@g)                        # ptr
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                        # byte
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                        # n
            _expect(@g, TK_RPAREN, "expected ')'")
            # mov rcx, rax (n)
            _em_mov_rcx_rax(@g)
            # pop rax (byte)
            _em_pop_rax(@g)
            # pop rdi (ptr)
            _eb(@g, 95)
            # rep stosb (f3 aa)
            _eb(@g, 243)
            _eb(@g, 170)
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        # sizeof intrinsic: returns 1/2/4/8 for primitive widths,
        # nfields*8 for user struct. Value folded at compile time.
        if str_eq(@name, "sizeof") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after sizeof")
            if _peek_kind(@g) != TK_IDENT
                _die(@g, "sizeof expects a type name")
                return 0
            @tname = _tok_substr(@g, @g.pos)
            _advance(@g)
            _expect(@g, TK_RPAREN, "expected ')'")
            @sz = 8
            if str_eq(@tname, "u8") == 1
                @sz = 1
            elif str_eq(@tname, "i8") == 1
                @sz = 1
            elif str_eq(@tname, "bool") == 1
                @sz = 1
            elif str_eq(@tname, "u16") == 1
                @sz = 2
            elif str_eq(@tname, "i16") == 1
                @sz = 2
            elif str_eq(@tname, "u32") == 1
                @sz = 4
            elif str_eq(@tname, "i32") == 1
                @sz = 4
            elif str_eq(@tname, "f32") == 1
                @sz = 4
            else
                @s_idx = _struct_lookup(@g, @tname)
                if @s_idx >= 0
                    @fields = vec_get(@g.struct_fields, @s_idx)
                    @sz = vec_len(@fields) * 8
            _em_mov_eax_imm(@g, @sz)
            return 0
        # str_set_byte(s, i, v) — writes byte v at s+i, returns 0.
        if str_eq(@name, "str_set_byte") == 1
            _advance(@g)
            _expect(@g, TK_LPAREN, "expected '(' after str_set_byte")
            parse_expr(@g)                 # s
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                 # i
            _em_push_rax(@g)
            _expect(@g, TK_COMMA, "expected ','")
            parse_expr(@g)                 # v  (rax)
            _expect(@g, TK_RPAREN, "expected ')'")
            # pop rcx (i)   — but we pushed s, then i, then v is in rax.
            # Stack top is i (last push), below is s.
            # Actually re-examine: we push s, push i, then v in rax.
            # Stack (top→bottom): i, s. rax = v.
            # We want: s in rdx, i in rcx, v in al.
            # mov r8, rax (v)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 192)
            # pop rcx (i)
            _eb(@g, 89)
            # pop rdx (s)
            _eb(@g, 90)
            # mov [rdx + rcx], r8b  ; 44 88 04 0a
            _eb(@g, 68)
            _eb(@g, 136)
            _eb(@g, 4)
            _eb(@g, 10)
            # xor eax, eax (return 0)
            _eb(@g, 49)
            _eb(@g, 192)
            return 0
        _advance(@g)
        # Optional generic type arguments: `foo<int, Point>(x, y)`.
        # Since all types are 8-byte-wide at runtime, we swallow them.
        _swallow_generic_params(@g)
        _expect(@g, TK_LPAREN, "expected '(' after call name")
        # Evaluate args into fixed stack slots so we can load regs in
        # order and also support >6 args (SysV stack-args live past r9).
        # Layout: rsp[0..N*8) after `sub rsp, N*8` holds arg[0..N-1].
        @nargs = 0
        # Emit `sub rsp, 0` placeholder — patch later with N*8 aligned.
        @sub_at = _code_len(@g)
        # sub rsp, imm32 ; 48 81 ec <imm32>
        _eb(@g, 72)
        _eb(@g, 129)
        _eb(@g, 236)
        _e32(@g, 0)
        @sub_imm_at = _code_len(@g) - 4
        if _peek_kind(@g) != TK_RPAREN
            parse_expr(@g)
            # mov [rsp + 0], rax
            _eb(@g, 72)
            _eb(@g, 137)
            _eb(@g, 4)
            _eb(@g, 36)
            @nargs = 1
            while _peek_kind(@g) == TK_COMMA
                _advance(@g)
                parse_expr(@g)
                # mov [rsp + nargs*8], rax  ; 48 89 84 24 <disp32>
                _eb(@g, 72)
                _eb(@g, 137)
                _eb(@g, 132)
                _eb(@g, 36)
                _e32(@g, @nargs * 8)
                @nargs = @nargs + 1
        _expect(@g, TK_RPAREN, "expected ')' after call args")
        # Patch the sub-rsp imm32 to actual N*8 (aligned up to 16).
        @alloc = @nargs * 8
        if (@alloc % 16) != 0
            @alloc = @alloc + 8
        _patch32(@g, @sub_imm_at, @alloc)
        # Load args 0..min(5, nargs-1) into sysv regs from slots.
        @nreg = @nargs
        if @nreg > 6
            @nreg = 6
        @i = 0
        while @i < @nreg
            # mov <argreg[i]>, [rsp + i*8]
            _em_load_argreg_stack(@g, @i, @i * 8)
            @i = @i + 1
        # If nargs > 6: slide stack args down so arg6 is at [rsp+0].
        # After `add rsp, 48` (reg arg slots freed), stack top has arg 6.
        if @nargs > 6
            # add rsp, 48
            _eb(@g, 72)
            _eb(@g, 131)
            _eb(@g, 196)
            _eb(@g, 48)
            # We still have (nargs-6)*8 bytes of args, plus the alignment
            # padding if any. Call site must see 16-aligned rsp, so the
            # stack-arg count must be even; caller adds a pad dword if
            # needed. For now we assume even stack-arg count.
        # Always emit an indirect call through the hot-swap dispatch
        # table: `call qword [rip + disp32]`. disp32 is patched to the
        # offset of the callee's slot inside the fn-slots array, which
        # is emitted at the end of the data section.  Initial slot
        # values point at the in-binary code, so behaviour is identical
        # to a direct call until `hot_install_patch` replaces the slot.
        @ph = _em_call_indirect_placeholder(@g)
        vec_push(@g.fn_patches, @ph)
        vec_push(@g.fn_patches, @name)
        # Clean up stack: if nargs <= 6, we did `sub rsp, alloc` and
        # never rolled it back, so `add rsp, alloc` restores. For
        # nargs > 6 we already added 48 above; now free the remaining
        # (nargs-6)*8 bytes, which equals (alloc - 48).
        if @nargs <= 6
            # add rsp, alloc
            _eb(@g, 72)
            _eb(@g, 129)
            _eb(@g, 196)
            _e32(@g, @alloc)
        else
            @remaining = @alloc - 48
            _eb(@g, 72)
            _eb(@g, 129)
            _eb(@g, 196)
            _e32(@g, @remaining)
        return 0
    _die(@g, "expected primary expression")
    _advance(@g)
    return 0


# --- Statement-level codegen -----------------------------------------
#
# Statements end with TK_NEWLINE. Blocks are delimited by
# TK_INDENT / TK_DEDENT tokens (produced by lex.luna).

# Record a forward patch into a data-string reference so we can resolve
# the lea disp32 once the code-to-data offset is known. We keep two
# parallel vecs: patch_code_off, patch_data_off.
fn _record_str_patch(@g: Gen, @code_off: int, @data_off: int, @patches: Vec) -> int
    vec_push(@patches, @code_off)
    vec_push(@patches, @data_off)
    return 0

# Parse a type expression starting at the current token. Returns a
# string describing the type, or "" if no type recognised. Accepts:
#   Ident                         int, u8, u32, Point, Gen, str, etc.
#   Ident < ... >                 Vec<T>, Option<T> — generics ignored
#   * [mut|const]? Ident          raw pointer (stored as "*Ident")
#   & [mut]? Ident                reference (stored as "&Ident")
#   [ Ident ]                     slice type (stored as "[Ident]")
#   [ Ident ; N ]                 fixed-size array (stored as "[Ident;N]")
#   Ident ?                       nullable (stored as "Ident?")
# Everything collapses to an 8-byte pointer/int at runtime.
fn _parse_type(@g: Gen) -> int
    @k = _peek_kind(@g)
    if @k == TK_STAR
        _advance(@g)
        if _peek_kind(@g) == TK_IDENT
            @maybe = _tok_substr(@g, @g.pos)
            if str_eq(@maybe, "mut") == 1
                _advance(@g)
            elif str_eq(@maybe, "const") == 1
                _advance(@g)
        if _peek_kind(@g) == TK_IDENT
            @inner = _tok_substr(@g, @g.pos)
            _advance(@g)
            return str_concat("*", @inner)
        return "*"
    if @k == TK_AMP
        _advance(@g)
        if _peek_kind(@g) == TK_IDENT
            @maybe = _tok_substr(@g, @g.pos)
            if str_eq(@maybe, "mut") == 1
                _advance(@g)
        if _peek_kind(@g) == TK_IDENT
            @inner = _tok_substr(@g, @g.pos)
            _advance(@g)
            return str_concat("&", @inner)
        return "&"
    if @k == TK_LBRACK
        _advance(@g)
        @elem = ""
        if _peek_kind(@g) == TK_IDENT
            @elem = _tok_substr(@g, @g.pos)
            _advance(@g)
        # Optional `; N` — we discard N for now; type is just "[T]"
        if _peek_kind(@g) == TK_SEMI
            _advance(@g)
            if _peek_kind(@g) == TK_INT
                _advance(@g)
        if _peek_kind(@g) == TK_RBRACK
            _advance(@g)
        return str_concat(str_concat("[", @elem), "]")
    if @k == TK_IDENT
        @t = _tok_substr(@g, @g.pos)
        _advance(@g)
        # Swallow generic parameter list `<T, U>`.
        if _peek_kind(@g) == TK_LT
            @depth = 1
            _advance(@g)
            while @depth > 0
                @tk = _peek_kind(@g)
                if @tk == TK_LT
                    @depth = @depth + 1
                elif @tk == TK_GT
                    @depth = @depth - 1
                elif @tk == TK_EOF
                    break
                _advance(@g)
        return @t
    return ""

# Common impl for `let`/`meow`/`seal` bindings: consumes the binding
# keyword, parses `@name [: type]? = expr`, stores into a fresh local.
# If @is_seal is 1, flag the local so reassignment fails.
fn _parse_typed_binding(@g: Gen, @is_seal: int) -> int
    _advance(@g)                                # consume let/meow/seal
    if _peek_kind(@g) != TK_ATIDENT
        _die(@g, "expected @name after binding keyword")
        return 0
    @lname = _tok_substr(@g, @g.pos)
    _advance(@g)
    @ltype = ""
    if _peek_kind(@g) == TK_COLON
        _advance(@g)
        @ltype = _parse_type(@g)
    _expect(@g, TK_ASSIGN, "expected '=' after binding")
    parse_expr(@g)
    @off = _local_slot(@g, @lname)
    if str_eq(@ltype, "") == 0
        _set_local_type(@g, @lname, @ltype)
    _em_store_rbp(@g, @off)
    if @is_seal == 1
        _seal_local(@g, @lname)
    return 0

# Returns 0 on normal statement, 1 if end-of-block (DEDENT/EOF) reached.
fn parse_stmt(@g: Gen, @patches: Vec) -> int
    _skip_newlines(@g)
    @k = _peek_kind(@g)
    if @k == TK_DEDENT
        return 1
    if @k == TK_EOF
        return 1

    if @k == TK_RETURN
        _advance(@g)
        parse_expr(@g)
        if @g.is_main == 1
            # main's return becomes process exit syscall.
            _em_mov_rdi_rax(@g)
            _em_mov_eax_imm(@g, 60)
            _em_syscall(@g)
        else
            # Normal fn return: mov rsp, rbp; pop rbp; ret
            _em_epilogue(@g)
        return 0

    # let / meow / seal binding forms (all typed-propagating).
    # `seal` additionally flags the local so subsequent writes are a
    # compile-time error.  `let` and `meow` are mutable (distinction
    # reserved for a future immutability-by-default pass).
    if @k == TK_KW_LET
        return _parse_typed_binding(@g, 0)
    if @k == TK_KW_MEOW
        return _parse_typed_binding(@g, 0)
    if @k == TK_KW_SEAL
        return _parse_typed_binding(@g, 1)

    if @k == TK_IF
        parse_if(@g, @patches)
        return 0

    if @k == TK_WHILE
        parse_while(@g, @patches)
        return 0

    if @k == TK_KW_MATCH
        parse_match(@g, @patches)
        return 0

    if @k == TK_KW_PHASE
        parse_match(@g, @patches)
        return 0

    if @k == TK_KW_BREAK
        _advance(@g)
        @top = vec_len(@g.loop_breaks) - 1
        if @top < 0
            _die(@g, "break outside loop")
            return 0
        @ph = _em_jmp_placeholder(@g)
        @bv = vec_get(@g.loop_breaks, @top)
        vec_push(@bv, @ph)
        return 0

    # Pointer write: *expr = expr   →  mov [ptr], val
    if @k == TK_STAR
        _advance(@g)
        parse_unary(@g)                        # rax = pointer (may contain * chains)
        _em_push_rax(@g)
        _expect(@g, TK_ASSIGN, "expected '=' after *expr")
        parse_expr(@g)                         # rax = value
        _em_mov_rcx_rax(@g)                    # rcx = value
        _em_pop_rax(@g)                        # rax = pointer
        # mov [rax], rcx  ; 48 89 08
        _eb(@g, 72)
        _eb(@g, 137)
        _eb(@g, 8)
        return 0

    if @k == TK_KW_CONTINUE
        _advance(@g)
        @top = vec_len(@g.loop_cont) - 1
        if @top < 0
            _die(@g, "continue outside loop")
            return 0
        @tgt = vec_get(@g.loop_cont, @top)
        _em_jmp_to(@g, @tgt)
        return 0

    if @k == TK_ATIDENT
        @name = _tok_substr(@g, @g.pos)
        _advance(@g)
        # Indexed write: @arr[i] = v
        if _peek_kind(@g) == TK_LBRACK
            _advance(@g)
            @off = _local_slot(@g, @name)
            _em_load_rbp(@g, @off)
            _em_push_rax(@g)
            parse_expr(@g)
            _expect(@g, TK_RBRACK, "expected ']'")
            _em_push_rax(@g)
            _expect(@g, TK_ASSIGN, "expected '='")
            parse_expr(@g)
            _eb(@g, 73)
            _eb(@g, 137)
            _eb(@g, 192)
            _eb(@g, 89)
            _eb(@g, 90)
            _eb(@g, 76)
            _eb(@g, 137)
            _eb(@g, 4)
            _eb(@g, 202)
            return 0
        # Field write: @obj.field = v
        if _peek_kind(@g) == TK_DOT
            _advance(@g)
            if _peek_kind(@g) != TK_IDENT
                _die(@g, "expected field name after '.'")
                return 0
            @fname = _tok_substr(@g, @g.pos)
            _advance(@g)
            _expect(@g, TK_ASSIGN, "expected '='")
            # Resolve field offset via owner's type.
            @tname = _local_type(@g, @name)
            @field_off = 0
            if str_eq(@tname, "") == 0
                @s_idx = _struct_lookup(@g, @tname)
                if @s_idx >= 0
                    @fi = _field_index(@g, @s_idx, @fname)
                    if @fi >= 0
                        @field_off = @fi * 8
            # Evaluate RHS into rax, save.
            parse_expr(@g)
            _em_push_rax(@g)
            # Load owner base into rax.
            @off = _local_slot(@g, @name)
            _em_load_rbp(@g, @off)
            _em_mov_rcx_rax(@g)                 # rcx = obj ptr
            _em_pop_rax(@g)                     # rax = value
            # mov [rcx + field_off], rax  ; 48 89 81 <disp32>
            _eb(@g, 72)
            _eb(@g, 137)
            _eb(@g, 129)
            _e32(@g, @field_off)
            return 0
        # Explicit type annotation: @x: T = expr
        if _peek_kind(@g) == TK_COLON
            _advance(@g)
            @ltype = ""
            if _peek_kind(@g) == TK_IDENT
                @ltype = _tok_substr(@g, @g.pos)
                _advance(@g)
            _expect(@g, TK_ASSIGN, "expected '=' after type ann")
            parse_expr(@g)
            @off = _local_slot(@g, @name)
            if str_eq(@ltype, "") == 0
                _set_local_type(@g, @name, @ltype)
            _em_store_rbp(@g, @off)
            return 0
        # Compound assignment: @x OP= expr  →  @x = @x OP expr
        @opk = _peek_kind(@g)
        if _is_compound_assign(@opk) == 1
            _advance(@g)
            @off = _local_slot(@g, @name)
            if _local_is_sealed(@g, @name) == 1
                _die(@g, str_concat("cannot reassign sealed local: ", @name))
                return 0
            _em_load_rbp(@g, @off)              # rax = current
            _em_push_rax(@g)
            parse_expr(@g)                       # rax = rhs
            _em_mov_rcx_rax(@g)                  # rcx = rhs
            _em_pop_rax(@g)                      # rax = current
            _emit_compound_op(@g, @opk)          # rax = rax OP rcx
            _em_store_rbp(@g, @off)
            return 0
        _expect(@g, TK_ASSIGN, "expected '='")
        parse_expr(@g)
        @off = _local_slot(@g, @name)
        if _local_is_sealed(@g, @name) == 1
            _die(@g, str_concat("cannot reassign sealed local: ", @name))
            return 0
        _em_store_rbp(@g, @off)
        return 0

    if @k == TK_IDENT
        @name = _tok_substr(@g, @g.pos)
        if str_eq(@name, "shine") == 1
            _advance(@g)
            parse_shine(@g, @patches)
            return 0
        if str_eq(@name, "shine_int") == 1
            _advance(@g)
            parse_shine_int(@g)
            return 0
        # General call-statement: reuse parse_primary's call path, which
        # leaves result in rax (discarded).
        parse_primary(@g)
        return 0

    _die(@g, "expected statement")
    _advance(@g)
    return 0


fn parse_shine(@g: Gen, @patches: Vec) -> int
    _expect(@g, TK_LPAREN, "expected '(' after shine")
    # Parse an arbitrary expression; result (string pointer) lands in rax.
    parse_expr(@g)
    _expect(@g, TK_RPAREN, "expected ')'")
    # Emit a syscall write(1, rax, len) where len is read from the
    # 8-byte length prefix at [rax-8]. Then write a newline from stack.
    # mov rsi, rax  ; 48 89 c6
    _eb(@g, 72)
    _eb(@g, 137)
    _eb(@g, 198)
    # mov rdx, [rax - 8]  ; 48 8b 50 f8
    _eb(@g, 72)
    _eb(@g, 139)
    _eb(@g, 80)
    _eb(@g, 248)
    # mov eax, 1; mov edi, 1; syscall
    _em_mov_eax_imm(@g, 1)
    _em_mov_edi_imm(@g, 1)
    _em_syscall(@g)
    # Write a newline via stack. sub rsp, 16; mov byte [rsp], 10;
    # mov eax,1; mov edi,1; mov rsi,rsp; mov edx,1; syscall; add rsp,16
    _eb(@g, 72)                # sub rsp, 16  ; 48 83 ec 10
    _eb(@g, 131)
    _eb(@g, 236)
    _eb(@g, 16)
    _eb(@g, 198)               # mov byte [rsp], 10  ; c6 04 24 0a
    _eb(@g, 4)
    _eb(@g, 36)
    _eb(@g, 10)
    _em_mov_eax_imm(@g, 1)
    _em_mov_edi_imm(@g, 1)
    _eb(@g, 72)                # mov rsi, rsp  ; 48 89 e6
    _eb(@g, 137)
    _eb(@g, 230)
    _em_mov_edx_imm(@g, 1)
    _em_syscall(@g)
    _eb(@g, 72)                # add rsp, 16  ; 48 83 c4 10
    _eb(@g, 131)
    _eb(@g, 196)
    _eb(@g, 16)
    return 0


fn parse_shine_int(@g: Gen) -> int
    _expect(@g, TK_LPAREN, "expected '(' after shine_int")
    parse_expr(@g)
    _expect(@g, TK_RPAREN, "expected ')'")
    _em_mov_rdi_rax(@g)
    _em_call_to(@g, @g.pi_off)
    return 0


fn parse_if(@g: Gen, @patches: Vec) -> int
    _advance(@g)                       # consume 'if'
    parse_expr(@g)                     # rax = cond
    _em_test_rax(@g)
    @jz_patch = _em_jz_placeholder(@g)
    # then-body
    _expect(@g, TK_NEWLINE, "newline after if")
    _expect(@g, TK_INDENT, "indented block after if")
    parse_block(@g, @patches)
    # collect end-of-chain patches so each branch can jump past the whole
    # if/elif/else chain.
    @end_patches = vec_new()
    vec_push(@end_patches, _em_jmp_placeholder(@g))
    _patch_here(@g, @jz_patch)
    # optional elif/else chain
    _skip_newlines(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_ELIF
            _advance(@g)
            parse_expr(@g)
            _em_test_rax(@g)
            @jz2 = _em_jz_placeholder(@g)
            _expect(@g, TK_NEWLINE, "newline after elif")
            _expect(@g, TK_INDENT, "indented block after elif")
            parse_block(@g, @patches)
            vec_push(@end_patches, _em_jmp_placeholder(@g))
            _patch_here(@g, @jz2)
            _skip_newlines(@g)
        elif @k == TK_ELSE
            _advance(@g)
            _expect(@g, TK_NEWLINE, "newline after else")
            _expect(@g, TK_INDENT, "indented block after else")
            parse_block(@g, @patches)
            break
        else
            break
    # Patch all end-jmps to here.
    @np = vec_len(@end_patches)
    @i = 0
    while @i < @np
        _patch_here(@g, vec_get(@end_patches, @i))
        @i = @i + 1
    return 0


fn parse_match(@g: Gen, @patches: Vec) -> int
    _advance(@g)                                # consume match / phase
    # Evaluate scrutinee and stash it in a fresh local slot so every
    # arm can re-read the pointer (we trample rax inside bodies).
    parse_expr(@g)
    @scrut_off = _local_slot(@g, "_match_scrut")
    _em_store_rbp(@g, @scrut_off)
    _expect(@g, TK_NEWLINE, "newline after match")
    _expect(@g, TK_INDENT, "indented match arms")
    # end_patches accumulates jmp offsets that each arm emits to skip
    # past the rest of the chain once it executes.
    @end_patches = vec_new()
    while 1
        _skip_newlines(@g)
        @k = _peek_kind(@g)
        if @k == TK_DEDENT
            _advance(@g)
            break
        if @k == TK_EOF
            break
        if @k != TK_IDENT
            _die(@g, "expected variant name in match arm")
            return 0
        @vname = _tok_substr(@g, @g.pos)
        @vi = _variant_index(@g, @vname)
        if @vi < 0
            _die(@g, str_concat("unknown variant in match: ", @vname))
            _advance(@g)
            return 0
        _advance(@g)
        @tag  = vec_get(@g.variant_tag,     @vi)
        @hasp = vec_get(@g.variant_payload, @vi)
        # Optional `(@bind)` payload binding.
        @bind_name = ""
        if _peek_kind(@g) == TK_LPAREN
            _advance(@g)
            if _peek_kind(@g) == TK_ATIDENT
                @bind_name = _tok_substr(@g, @g.pos)
                _advance(@g)
            _expect(@g, TK_RPAREN, "expected ')' in match pattern")
        _expect(@g, TK_NEWLINE, "newline after match arm pattern")
        _expect(@g, TK_INDENT, "indented match arm body")
        # Compare tag: mov rax, [rbp+scrut] ; mov rax, [rax] ; cmp rax, tag ; jne next
        _em_load_rbp(@g, @scrut_off)
        _eb(@g, 72)                             # mov rax, [rax]  ; 48 8b 00
        _eb(@g, 139)
        _eb(@g, 0)
        # cmp rax, imm32: 48 3d <imm32>
        _eb(@g, 72)
        _eb(@g, 61)
        _e32(@g, @tag)
        # jne next (jnz rel32 = 0f 85)
        _eb(@g, 15)
        _eb(@g, 133)
        @jne_at = _code_len(@g)
        _e32(@g, 0)
        # If the arm binds a payload, load scrut.payload into the
        # named local so the body can reference it.
        if @hasp == 1
            if str_eq(@bind_name, "") == 0
                _em_load_rbp(@g, @scrut_off)
                _eb(@g, 72)                     # mov rax, [rax + 8] ; 48 8b 40 08
                _eb(@g, 139)
                _eb(@g, 64)
                _eb(@g, 8)
                @bind_off = _local_slot(@g, @bind_name)
                _em_store_rbp(@g, @bind_off)
        parse_block(@g, @patches)
        # After body, jmp past the rest of the chain.
        vec_push(@end_patches, _em_jmp_placeholder(@g))
        # Resolve the jne to here (next arm).
        _patch_here(@g, @jne_at)
    # Patch every end_patches jmp to current position.
    @np = vec_len(@end_patches)
    @i = 0
    while @i < @np
        _patch_here(@g, vec_get(@end_patches, @i))
        @i = @i + 1
    return 0


fn parse_while(@g: Gen, @patches: Vec) -> int
    _advance(@g)                       # consume 'while'
    @loop_start = _code_len(@g)
    # Push new loop frame: continue target = loop_start, fresh break-vec.
    vec_push(@g.loop_cont, @loop_start)
    @bvec = vec_new()
    vec_push(@g.loop_breaks, @bvec)
    parse_expr(@g)
    _em_test_rax(@g)
    @jz_patch = _em_jz_placeholder(@g)
    _expect(@g, TK_NEWLINE, "newline after while")
    _expect(@g, TK_INDENT, "indented block after while")
    parse_block(@g, @patches)
    _em_jmp_to(@g, @loop_start)
    _patch_here(@g, @jz_patch)
    # Pop loop frame and patch any break jumps to current code position.
    @top = vec_len(@g.loop_breaks) - 1
    @bv = vec_get(@g.loop_breaks, @top)
    @nb = vec_len(@bv)
    @i = 0
    while @i < @nb
        _patch_here(@g, vec_get(@bv, @i))
        @i = @i + 1
    vec_pop(@g.loop_breaks)
    vec_pop(@g.loop_cont)
    return 0


# Parse statements until a DEDENT closes the block.
fn parse_block(@g: Gen, @patches: Vec) -> int
    while 1
        _skip_newlines(@g)
        @k = _peek_kind(@g)
        if @k == TK_DEDENT
            _advance(@g)
            return 0
        if @k == TK_EOF
            return 0
        parse_stmt(@g, @patches)
    return 0


# Parse one `fn name(params) -> type` declaration and emit its code.
fn parse_fn(@g: Gen, @patches: Vec) -> int
    _skip_newlines(@g)
    _expect(@g, TK_FN, "expected 'fn'")
    if _peek_kind(@g) != TK_IDENT
        _die(@g, "expected function name after 'fn'")
        return 1
    @fn_name = _tok_substr(@g, @g.pos)
    _advance(@g)

    # Optional generic parameter list `<T, U: Trait>`. In Luna's
    # 8-byte uniform value model every type is an 8-byte slot at
    # runtime, so the parameters are purely documentation. We
    # swallow tokens up to the matching `>` without interpreting.
    _swallow_generic_params(@g)

    # Register fn NAME at current code offset (before prologue).
    @fn_off = _code_len(@g)
    _fn_register(@g, @fn_name, @fn_off)
    if str_eq(@fn_name, "main") == 1
        @g.is_main  = 1
        @g.main_off = @fn_off
    else
        @g.is_main = 0

    _expect(@g, TK_LPAREN, "expected '(' in fn decl")
    # Reset per-function locals.
    _reset_locals(@g)

    # Collect param names + types. Types (if present) become the local's
    # type so field accesses in the body resolve correctly.
    @param_names = vec_new()
    @param_types = vec_new()
    if _peek_kind(@g) != TK_RPAREN
        if _peek_kind(@g) != TK_ATIDENT
            _die(@g, "expected parameter (@name)")
            return 1
        vec_push(@param_names, _tok_substr(@g, @g.pos))
        _advance(@g)
        @pty = ""
        if _peek_kind(@g) == TK_COLON
            _advance(@g)
            @pty = _parse_type(@g)
        vec_push(@param_types, @pty)
        while _peek_kind(@g) == TK_COMMA
            _advance(@g)
            if _peek_kind(@g) != TK_ATIDENT
                _die(@g, "expected parameter (@name)")
                return 1
            vec_push(@param_names, _tok_substr(@g, @g.pos))
            _advance(@g)
            @pty2 = ""
            if _peek_kind(@g) == TK_COLON
                _advance(@g)
                @pty2 = _parse_type(@g)
            vec_push(@param_types, @pty2)
    _expect(@g, TK_RPAREN, "expected ')' in fn decl")

    # Optional `-> type` — use the full type parser to support
    # generics, references, pointers, slices, etc.
    if _peek_kind(@g) == TK_ARROW
        _advance(@g)
        @_ret_ty = _parse_type(@g)

    _expect(@g, TK_NEWLINE, "newline after fn signature")
    _expect(@g, TK_INDENT, "indented fn body")

    # Emit prologue (frame size patched later).
    @prol_at = _em_prologue(@g)

    # Spill register args 0..5 and load stack args 6..N-1 into local slots.
    @nparams = vec_len(@param_names)
    @pi = 0
    while @pi < @nparams
        @pname = vec_get(@param_names, @pi)
        @ptype = vec_get(@param_types, @pi)
        @poff  = _local_slot(@g, @pname)
        if str_eq(@ptype, "") == 0
            _set_local_type(@g, @pname, @ptype)
        if @pi < 6
            # mov rax, <sysv_arg_reg[pi]> ; mov [rbp+poff], rax
            _em_mov_rax_argreg(@g, @pi)
        else
            # Stack-passed arg: at [rbp + 16 + (pi-6)*8]
            @src_disp = 16 + (@pi - 6) * 8
            _em_load_rbp(@g, @src_disp)
        _em_store_rbp(@g, @poff)
        @pi = @pi + 1

    parse_block(@g, @patches)

    # Implicit return: main exits with 0, other fns do `return 0`.
    if @g.is_main == 1
        _em_mov_edi_imm(@g, 0)
        _em_mov_eax_imm(@g, 60)
        _em_syscall(@g)
    else
        _em_mov_eax_imm(@g, 0)
        _em_epilogue(@g)

    # Patch frame size.
    @sz = @g.frame
    if @sz < 16
        @sz = 16
    if (@sz % 16) != 0
        @sz = @sz + (16 - (@sz % 16))
    _patch32(@g, @prol_at, @sz)
    return 0


# mov rax, <sysv_arg_reg[i]>  — inverse of _em_mov_argreg_rax.
fn _em_mov_rax_argreg(@g: Gen, @i: int) -> int
    if @i == 0
        _eb(@g, 72)                  # mov rax, rdi  ; 48 89 f8
        _eb(@g, 137)
        _eb(@g, 248)
        return 0
    if @i == 1
        _eb(@g, 72)                  # mov rax, rsi  ; 48 89 f0
        _eb(@g, 137)
        _eb(@g, 240)
        return 0
    if @i == 2
        _eb(@g, 72)                  # mov rax, rdx  ; 48 89 d0
        _eb(@g, 137)
        _eb(@g, 208)
        return 0
    if @i == 3
        _eb(@g, 72)                  # mov rax, rcx  ; 48 89 c8
        _eb(@g, 137)
        _eb(@g, 200)
        return 0
    if @i == 4
        _eb(@g, 76)                  # mov rax, r8   ; 4c 89 c0
        _eb(@g, 137)
        _eb(@g, 192)
        return 0
    if @i == 5
        _eb(@g, 76)                  # mov rax, r9   ; 4c 89 c8
        _eb(@g, 137)
        _eb(@g, 200)
        return 0
    return 0


# Parse `struct Name[<T, U>] <indent> field1: type <newline> ...`
fn parse_struct_decl(@g: Gen) -> int
    _advance(@g)                          # consume 'struct'
    if _peek_kind(@g) != TK_IDENT
        _die(@g, "expected struct name")
        return 1
    @sname = _tok_substr(@g, @g.pos)
    _advance(@g)
    _swallow_generic_params(@g)
    _expect(@g, TK_NEWLINE, "newline after struct name")
    _expect(@g, TK_INDENT, "indented struct fields")
    @fields = vec_new()
    while 1
        _skip_newlines(@g)
        @k = _peek_kind(@g)
        if @k == TK_DEDENT
            _advance(@g)
            break
        if @k == TK_EOF
            break
        if @k != TK_IDENT
            _die(@g, "expected field name")
            return 1
        @fname = _tok_substr(@g, @g.pos)
        _advance(@g)
        if _peek_kind(@g) == TK_COLON
            _advance(@g)
            @_field_ty = _parse_type(@g)
        vec_push(@fields, @fname)
    _struct_register(@g, @sname, @fields)
    return 0


# Skip an `extern "C" fn name(...) -> type` declaration. We do not
# emit code; the name is registered as a known external that triggers
# syscall intrinsics when called.
fn parse_extern_decl(@g: Gen) -> int
    _advance(@g)                          # consume 'extern'
    if _peek_kind(@g) == TK_STR
        _advance(@g)                       # consume "C"
    if _peek_kind(@g) == TK_FN
        _advance(@g)
    if _peek_kind(@g) == TK_IDENT
        _advance(@g)                       # consume name
    # Skip params up to ')'
    if _peek_kind(@g) == TK_LPAREN
        @depth = 1
        _advance(@g)
        while @depth > 0
            @k = _peek_kind(@g)
            if @k == TK_LPAREN
                @depth = @depth + 1
            elif @k == TK_RPAREN
                @depth = @depth - 1
            elif @k == TK_EOF
                break
            _advance(@g)
    # Optional return type
    if _peek_kind(@g) == TK_ARROW
        _advance(@g)
        if _peek_kind(@g) == TK_IDENT
            _advance(@g)
    # Consume trailing newline
    while _peek_kind(@g) == TK_NEWLINE
        _advance(@g)
    return 0

# Skip an `import modname` line. No-op since we compile concatenated
# source monoliths.
fn parse_import(@g: Gen) -> int
    _advance(@g)
    if _peek_kind(@g) == TK_IDENT
        _advance(@g)
    while _peek_kind(@g) == TK_NEWLINE
        _advance(@g)
    return 0

# Parse a const-expression: integer literal, other const reference,
# or a small arithmetic/bitwise expression over those.
# Grammar (precedence-climbing, very small):
#   cexpr  := cand ('|' cand)*
#   cand   := cxor ('^' cxor)*
#   cxor   := cand_and ('&' cand_and)*
#   cand_and := cshift (('<<' | '>>') cshift)*
#   cshift := cadd ...      # same precedence as runtime
#   cadd   := cmul (('+' | '-') cmul)*
#   cmul   := cunary (('*' | '/' | '%') cunary)*
#   cunary := ('-' | '~')? cprimary
#   cprimary := INT | `(` cexpr `)` | NAME
fn _const_eval_primary(@g: Gen) -> int
    @k = _peek_kind(@g)
    if @k == TK_INT
        @v = _peek_iv(@g)
        _advance(@g)
        return @v
    if @k == TK_LPAREN
        _advance(@g)
        @v = _const_eval_expr(@g)
        if _peek_kind(@g) == TK_RPAREN
            _advance(@g)
        return @v
    if @k == TK_IDENT
        @name = _tok_substr(@g, @g.pos)
        _advance(@g)
        @out = vec_new()
        if _const_lookup(@g, @name, @out) == 1
            return vec_get(@out, 0)
        return 0
    return 0

fn _const_eval_unary(@g: Gen) -> int
    if _peek_kind(@g) == TK_MINUS
        _advance(@g)
        return 0 - _const_eval_unary(@g)
    if _peek_kind(@g) == TK_TILDE
        _advance(@g)
        return ~_const_eval_unary(@g)
    return _const_eval_primary(@g)

fn _const_eval_mul(@g: Gen) -> int
    @v = _const_eval_unary(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_STAR
            _advance(@g)
            @v = @v * _const_eval_unary(@g)
        elif @k == TK_SLASH
            _advance(@g)
            @v = @v / _const_eval_unary(@g)
        elif @k == TK_PERCENT
            _advance(@g)
            @v = @v % _const_eval_unary(@g)
        else
            break
    return @v

fn _const_eval_add(@g: Gen) -> int
    @v = _const_eval_mul(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_PLUS
            _advance(@g)
            @v = @v + _const_eval_mul(@g)
        elif @k == TK_MINUS
            _advance(@g)
            @v = @v - _const_eval_mul(@g)
        else
            break
    return @v

fn _const_eval_shift(@g: Gen) -> int
    @v = _const_eval_add(@g)
    while 1
        @k = _peek_kind(@g)
        if @k == TK_SHL
            _advance(@g)
            @v = @v << _const_eval_add(@g)
        elif @k == TK_SHR
            _advance(@g)
            @v = @v >> _const_eval_add(@g)
        else
            break
    return @v

fn _const_eval_band(@g: Gen) -> int
    @v = _const_eval_shift(@g)
    while _peek_kind(@g) == TK_AMP
        _advance(@g)
        @v = @v & _const_eval_shift(@g)
    return @v

fn _const_eval_bxor(@g: Gen) -> int
    @v = _const_eval_band(@g)
    while _peek_kind(@g) == TK_CARET
        _advance(@g)
        @v = @v ^ _const_eval_band(@g)
    return @v

fn _const_eval_expr(@g: Gen) -> int
    @v = _const_eval_bxor(@g)
    while _peek_kind(@g) == TK_PIPE
        _advance(@g)
        @v = @v | _const_eval_bxor(@g)
    return @v

# Parse `const NAME: type = <const-expr>` at module level. Records the
# (name, value) pair for compile-time substitution at use sites.
fn parse_const_decl(@g: Gen) -> int
    _advance(@g)                           # consume 'const'
    @cname = ""
    if _peek_kind(@g) == TK_IDENT
        @cname = _tok_substr(@g, @g.pos)
        _advance(@g)
    if _peek_kind(@g) == TK_COLON
        _advance(@g)
        # Skip the (primitive) type annotation — we don't use it.
        @_ty = _parse_type(@g)
    @cval = 0
    if _peek_kind(@g) == TK_ASSIGN
        _advance(@g)
        @cval = _const_eval_expr(@g)
    if str_eq(@cname, "") == 0
        vec_push(@g.const_names, @cname)
        vec_push(@g.const_values, @cval)
    while _peek_kind(@g) == TK_NEWLINE
        _advance(@g)
    return 0

# Look up a const name; returns (1, value) if found, (0, 0) otherwise.
# Encoded as: set @g.frame to... nope, we'll just return -1 for missing
# and require caller to check via helper below.
fn _const_lookup(@g: Gen, @name: int, @out: Vec) -> int
    @n = vec_len(@g.const_names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.const_names, @i), @name) == 1
            vec_push(@out, vec_get(@g.const_values, @i))
            return 1
        @i = @i + 1
    return 0

# Parse `enum Name <indent> V1 <newline> V2(int) <newline> ...` and
# register variants so constructors and match arms can resolve names.
fn parse_enum_decl(@g: Gen) -> int
    _advance(@g)                              # consume 'enum'
    if _peek_kind(@g) != TK_IDENT
        _die(@g, "expected enum name")
        return 1
    @ename = _tok_substr(@g, @g.pos)
    _advance(@g)
    _swallow_generic_params(@g)
    _expect(@g, TK_NEWLINE, "newline after enum name")
    _expect(@g, TK_INDENT, "indented enum body")
    vec_push(@g.enum_names, @ename)
    @tag = 0
    while 1
        _skip_newlines(@g)
        @k = _peek_kind(@g)
        if @k == TK_DEDENT
            _advance(@g)
            break
        if @k == TK_EOF
            break
        if @k != TK_IDENT
            _die(@g, "expected variant name")
            return 1
        @vname = _tok_substr(@g, @g.pos)
        _advance(@g)
        @has_p = 0
        if _peek_kind(@g) == TK_LPAREN
            _advance(@g)
            # Skip the payload type (one identifier); reject multi-arg for now.
            if _peek_kind(@g) == TK_IDENT
                _advance(@g)
            _expect(@g, TK_RPAREN, "expected ')' after variant type")
            @has_p = 1
        vec_push(@g.variant_enum, @ename)
        vec_push(@g.variant_name, @vname)
        vec_push(@g.variant_tag, @tag)
        vec_push(@g.variant_payload, @has_p)
        @tag = @tag + 1
    return 0


# Look up a variant by NAME (scanning the flat variant table).
# Returns index if found, -1 otherwise. Caller reads tag / payload /
# enum from the parallel vecs.
fn _variant_index(@g: Gen, @name: int) -> int
    @n = vec_len(@g.variant_name)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.variant_name, @i), @name) == 1
            return @i
        @i = @i + 1
    return 0 - 1


# Re-enter the token stream at a recorded lambda position and emit the
# lambda body as a synthetic top-level fn under @syn. Mirrors parse_fn
# except it doesn't read a fn name from source — the caller supplies it.
# When captures exist for this lambda, rdi holds the env block so we
# prepend a hidden __env param and load each captured value from env
# into a local before the user body runs.
fn _parse_lambda_body(@g: Gen, @syn: int, @patches: Vec) -> int
    # Look up captures recorded for this lambda at expression time.
    @lami = 0 - 1
    @lan  = vec_len(@g.lambda_names)
    @lii  = 0
    while @lii < @lan
        if str_eq(vec_get(@g.lambda_names, @lii), @syn) == 1
            @lami = @lii
            break
        @lii = @lii + 1
    @caps = vec_new()
    @ncaps = 0
    if @lami >= 0
        @caps = vec_get(@g.lambda_captures, @lami)
        @ncaps = vec_len(@caps)
    _expect(@g, TK_FN, "expected 'fn' at lambda start")
    _swallow_generic_params(@g)
    @fn_off = _code_len(@g)
    _fn_register(@g, @syn, @fn_off)
    @g.is_main = 0
    _expect(@g, TK_LPAREN, "expected '(' in lambda decl")
    _reset_locals(@g)
    @param_names = vec_new()
    @param_types = vec_new()
    # Prepend hidden __env as first arg if this lambda captures anything.
    if @ncaps > 0
        vec_push(@param_names, "__env")
        vec_push(@param_types, "")
    if _peek_kind(@g) != TK_RPAREN
        if _peek_kind(@g) != TK_ATIDENT
            _die(@g, "expected lambda parameter (@name)")
            return 1
        vec_push(@param_names, _tok_substr(@g, @g.pos))
        _advance(@g)
        @pty = ""
        if _peek_kind(@g) == TK_COLON
            _advance(@g)
            @pty = _parse_type(@g)
        vec_push(@param_types, @pty)
        while _peek_kind(@g) == TK_COMMA
            _advance(@g)
            if _peek_kind(@g) != TK_ATIDENT
                _die(@g, "expected lambda parameter (@name)")
                return 1
            vec_push(@param_names, _tok_substr(@g, @g.pos))
            _advance(@g)
            @pty2 = ""
            if _peek_kind(@g) == TK_COLON
                _advance(@g)
                @pty2 = _parse_type(@g)
            vec_push(@param_types, @pty2)
    _expect(@g, TK_RPAREN, "expected ')' in lambda decl")
    if _peek_kind(@g) == TK_ARROW
        _advance(@g)
        @_lt = _parse_type(@g)
    _expect(@g, TK_NEWLINE, "newline after lambda signature")
    _expect(@g, TK_INDENT, "indented lambda body")
    @prol_at = _em_prologue(@g)
    @nparams = vec_len(@param_names)
    @pi = 0
    while @pi < @nparams
        @pname = vec_get(@param_names, @pi)
        @ptype = vec_get(@param_types, @pi)
        @poff  = _local_slot(@g, @pname)
        if str_eq(@ptype, "") == 0
            _set_local_type(@g, @pname, @ptype)
        if @pi < 6
            _em_mov_rax_argreg(@g, @pi)
        else
            @src_disp = 16 + (@pi - 6) * 8
            _em_load_rbp(@g, @src_disp)
        _em_store_rbp(@g, @poff)
        @pi = @pi + 1
    # Materialise captured values from the env block into named locals.
    if @ncaps > 0
        @env_off = _local_slot(@g, "__env")
        @lci = 0
        while @lci < @ncaps
            @cname = vec_get(@caps, @lci)
            @coff  = _local_slot(@g, @cname)    # fresh local
            _em_load_rbp(@g, @env_off)          # rax = env block
            # mov rax, [rax + 8*(1+lci)] ; 48 8b 80 <disp32>
            _eb(@g, 72)
            _eb(@g, 139)
            _eb(@g, 128)
            _e32(@g, (1 + @lci) * 8)
            _em_store_rbp(@g, @coff)
            @lci = @lci + 1
    parse_block(@g, @patches)
    _em_mov_eax_imm(@g, 0)
    _em_epilogue(@g)
    @sz = @g.frame
    if @sz < 16
        @sz = 16
    if (@sz % 16) != 0
        @sz = @sz + (16 - (@sz % 16))
    _patch32(@g, @prol_at, @sz)
    return 0


# Iterate over every lambda recorded during parse_program and emit its
# body as a synthetic top-level fn. Called after parse_program finishes
# so that real fns are laid out first and the lambdas extend the code
# section before the hot-swap table is appended to data.
fn _emit_deferred_lambdas(@g: Gen, @patches: Vec) -> int
    @nlam = vec_len(@g.lambda_names)
    @li = 0
    while @li < @nlam
        @ln = vec_get(@g.lambda_names,  @li)
        @lp = vec_get(@g.lambda_starts, @li)
        @saved = @g.pos
        @g.pos = @lp
        _parse_lambda_body(@g, @ln, @patches)
        @g.pos = @saved
        @li = @li + 1
    return 0


# Parse a whole program = sequence of fn decls + struct decls + etc.
fn parse_program(@g: Gen, @patches: Vec) -> int
    while 1
        _skip_newlines(@g)
        @k = _peek_kind(@g)
        if @k == TK_EOF
            return 0
        if @k == TK_FN
            parse_fn(@g, @patches)
        elif @k == TK_KW_STRUCT
            parse_struct_decl(@g)
        elif @k == TK_KW_ENUM
            parse_enum_decl(@g)
        elif @k == TK_KW_EXTERN
            parse_extern_decl(@g)
        elif @k == TK_KW_IMPORT
            parse_import(@g)
        elif @k == TK_KW_CONST
            parse_const_decl(@g)
        else
            _die(@g, "expected fn/struct/enum/extern/import/const at top level")
            _advance(@g)
    return 0


# --- Top-level entry: compile source → (code_bytes, data_bytes) ------

fn compile_to_gen(@src: int) -> Gen
    @kind = vec_new()
    @start = vec_new()
    @tlen = vec_new()
    @iv = vec_new()
    lex(@src, @kind, @start, @tlen, @iv)
    let @g: Gen = gen_new(@src, @kind, @start, @tlen, @iv)
    # Emit print_int runtime first so shine_int can call it.
    _emit_print_int(@g)
    # Parse all fn decls; str_patches is filled on the go via parse_shine.
    parse_program(@g, @g.str_patches)

    # Emit any deferred lambda bodies now, extending the code section
    # before the hot-swap table gets appended to data.
    _emit_deferred_lambdas(@g, @g.str_patches)

    # Emit the hot-swap function table at the end of the data section.
    # Layout (all u64, little-endian):
    #   fn_slots[N]  — absolute code vaddr of each user fn (mutable at
    #                  runtime; filled with initial values by main2)
    #   fn_names[N]  — absolute vaddr of each fn's name in the pool
    #                  (filled by main2)
    #   name pool    — NUL-terminated fn names, concatenated
    @nfn = vec_len(@g.fn_names)
    @g.hot_slots_off = _sb_len(@g.data)
    @zi = 0
    while @zi < @nfn * 8
        strbuf_add_byte(@g.data, 0)
        @zi = @zi + 1
    @g.hot_names_off = _sb_len(@g.data)
    @zi = 0
    while @zi < @nfn * 8
        strbuf_add_byte(@g.data, 0)
        @zi = @zi + 1
    @g.hot_pool_off  = _sb_len(@g.data)
    @pi = 0
    while @pi < @nfn
        @nm = vec_get(@g.fn_names, @pi)
        @nl = str_len(@nm)
        @ci = 0
        while @ci < @nl
            strbuf_add_byte(@g.data, str_byte(@nm, @ci))
            @ci = @ci + 1
        strbuf_add_byte(@g.data, 0)
        @pi = @pi + 1

    # Resolve forward fn-call patches. Every user-fn call emits an
    # indirect `call qword [rip+disp32]` whose disp32 points to the
    # callee's slot in fn_slots. Both call site and slot live in the
    # same PT_LOAD segment, and since the ELF writes data right after
    # code in the file image, we compute the delta in file coordinates.
    #
    # Layout when the patch fires:
    #   code section at file offset 0         ... ends at code_len
    #   data section at file offset code_len  ... slot i at
    #                                          code_len + hot_slots_off + i*8
    #
    # RIP at the call instruction = file offset (call_site + 4).
    # disp = slot_file_off - (call_site + 4)
    #      = (code_len + hot_slots_off + i*8) - (call_site + 4)
    @code_len_snap = _code_len(@g)
    @nfp = vec_len(@g.fn_patches)
    @i = 0
    while @i < @nfp
        @call_site = vec_get(@g.fn_patches, @i)
        @cname     = vec_get(@g.fn_patches, @i + 1)
        @tgt = _fn_lookup(@g, @cname)
        if @tgt < 0
            print("bootminor: undefined fn: ")
            shine(@cname)
        else
            @slot_idx = _fn_name_index(@g, @cname)
            @slot_file_off = @code_len_snap + @g.hot_slots_off + @slot_idx * 8
            @disp = @slot_file_off - (@call_site + 4)
            _patch32(@g, @call_site, @disp)
        @i = @i + 2
    return @g

# Swallow `<T, U, V: Trait>` generic parameter list if present.
# Luna compiles every type to an 8-byte slot so these parameters
# don't affect codegen — they exist for documentation and future
# type-check phases.
fn _swallow_generic_params(@g: Gen) -> int
    if _peek_kind(@g) != TK_LT
        return 0
    @depth = 1
    _advance(@g)
    while @depth > 0
        @k = _peek_kind(@g)
        if @k == TK_LT
            @depth = @depth + 1
        elif @k == TK_GT
            @depth = @depth - 1
        elif @k == TK_SHR
            # `>>` as two closers (e.g. `Vec<Option<T>>`) — bootminor's
            # lexer emits TK_SHR for consecutive `>>`, so treat it as
            # two `>` tokens here.
            @depth = @depth - 2
        elif @k == TK_EOF
            break
        _advance(@g)
    return 0

# Lookup a function's index in fn_names (== its slot index in the
# hot-swap table). -1 if not found.
fn _fn_name_index(@g: Gen, @name: int) -> int
    @n = vec_len(@g.fn_names)
    @i = 0
    while @i < @n
        if str_eq(vec_get(@g.fn_names, @i), @name) == 1
            return @i
        @i = @i + 1
    return 0 - 1
