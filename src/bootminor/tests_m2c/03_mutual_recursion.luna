fn is_even(@n: int) -> int
    if @n == 0
        return 1
    return is_odd(@n - 1)

fn is_odd(@n: int) -> int
    if @n == 0
        return 0
    return is_even(@n - 1)

fn main() -> int
    shine_int(is_even(0))
    shine_int(is_even(1))
    shine_int(is_even(2))
    shine_int(is_even(3))
    shine_int(is_even(4))
    shine_int(is_even(5))
    return 0
