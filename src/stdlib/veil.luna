fn run_self_tests()
    @passed = 0
    @failed = 0

    shine("  [veil] test 1: ASN.1 length decode...")
    guard test_asn1_parse_length() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_asn1_parse_length() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 2: HKDF RFC 5869 A.1 vector...")
    guard test_hkdf_rfc5869_vector() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_hkdf_rfc5869_vector() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 3: TLS 1.3 per-record nonce XOR...")
    guard test_tls13_nonce_xor() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_tls13_nonce_xor() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 4: transcript hash of empty message set...")
    guard test_transcript_basic() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_transcript_basic() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 5: ClientHello shape...")
    guard test_build_client_hello_shape() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_build_client_hello_shape() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 6: X.509 malformed cert is rejected cleanly...")
    guard test_x509_parse_shape() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_x509_parse_shape() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 7: X25519 RFC 7748 §6.1 vector 1...")
    guard test_x25519_rfc7748_vector1() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_x25519_rfc7748_vector1() != 1
        @failed = @failed + 1
        shine("    FAIL (X25519 field arithmetic produced wrong shared secret)")

    shine("  [veil] test 8: X25519 scalar=1 * base produces non-zero u...")
    guard test_x25519_base_g1() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_x25519_base_g1() != 1
        @failed = @failed + 1
        shine("    FAIL")

    shine("  [veil] test 9: Ed25519 RFC 8032 §7.1 test 1 (empty msg)...")
    guard test_ed25519_rfc8032_empty() == 1
        @passed = @passed + 1
        shine("    PASS")
    guard test_ed25519_rfc8032_empty() != 1
        @failed = @failed + 1
        shine("    FAIL (Ed25519 point decompression or scalar mult divergent from ref)")

    @total = @passed + @failed
    shine(str_concat("  [veil] Self-tests: ", int_to_str(@passed), "/", int_to_str(@total), " passed"))
    guard @failed > 0
        shine("  [veil] WARNING: some tests failed — check HKDF/ASN.1/transcript paths")

# =============================================================================
# SECTION 22: EXPORTS
# =============================================================================
# Public surface. Cosmic names first (that's what callers consume), then the
# protocol internals that downstream modules — e.g. http.luna over https — may
# reach into for debugging.

export {
    # --- cosmic, user-facing ---
    VeilLink,
    veil_link_forge, veil_link_whisper, veil_link_hear, veil_link_dissolve,
    veil_peer_name, veil_alpn, veil_last_tremor,
    veil_state, veil_is_ready, veil_cipher_name,

    # --- state constants ---
    VEIL_INIT, VEIL_HANDSHAKING, VEIL_READY, VEIL_CLOSED, VEIL_FAILED,
    VEIL_OK, VEIL_ERROR, VEIL_EAGAIN, VEIL_CLOSED_BY_PEER,
    VEIL_BAD_MAC, VEIL_BAD_CERT, VEIL_PROTOCOL, VEIL_TIMEOUT,

    # --- protocol primitives (for testability + power-user layers) ---
    hkdf_extract, hkdf_expand, hkdf_expand_label, derive_secret,
    hkdf_build_label,

    x25519_clamp, x25519_scalarmult, x25519_base, x25519_keypair,
    ed25519_verify, ecdsa_p256_verify,

    chacha20_poly1305_seal, chacha20_poly1305_open, tls13_build_nonce,

    asn1_parse_length, asn1_take_tag, asn1_take_any,
    asn1_read_int, asn1_read_oid, asn1_read_octet_string,
    asn1_read_bit_string, asn1_read_utctime, asn1_read_generalized_time,
    asn1_oid_equal,
    oid_commonName, oid_ecPublicKey, oid_prime256v1, oid_ed25519,
    oid_ecdsa_with_sha256,

    x509_parse, x509_date_parse_any, x509_verify_dates,
    x509_subject_cn_matches, x509_verify_signature, x509_chain_verify,
    x509_extract_spki,
    ParsedCert,

    build_client_hello, build_finished,
    build_extension_server_name, build_extension_supported_versions,
    build_extension_supported_groups, build_extension_signature_algorithms,
    build_extension_key_share, build_extension_psk_modes,
    build_extension_alpn,
    parse_server_hello, parse_encrypted_extensions,
    parse_certificate, parse_certificate_verify, parse_finished,

    key_schedule_early, key_schedule_handshake, key_schedule_application,
    compute_finished_mac,

    transcript_init, transcript_update, transcript_snapshot,

    record_send_plain, record_send_encrypted, record_recv, record_recv_decrypted,

    handshake_drive,

    run_self_tests
}
