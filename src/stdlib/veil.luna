    @sig[25] = 0x73
    @sig[26] = 0xE0
    @sig[27] = 0x65
    @sig[28] = 0x22
    @sig[29] = 0x49
    @sig[30] = 0x01
    @sig[31] = 0x55
    @sig[32] = 0x5F
    @sig[33] = 0xB8
    @sig[34] = 0x82
    @sig[35] = 0x15
    @sig[36] = 0x90
    @sig[37] = 0xA3
