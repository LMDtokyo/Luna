# Unit tests for std/net/http parsers.
#
# End-to-end GET tests live in tests/std/net/http_get.sh (Python
# http.server fixture).

import http
import test


fn run_http_tests(@p: int, @f: int) -> int
    @r = 0

    # 1) Status-line parser: "HTTP/1.1 200 OK\r\n..." -> 200.
    @line200 = "HTTP/1.1 200 OK\r\n"
    @s = _http_parse_status(@line200, str_len(@line200))
    @r = assert_eq_int("parse status 200", @s, 200)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 2) Status 404.
    @line404 = "HTTP/1.1 404 Not Found\r\n"
    @s = _http_parse_status(@line404, str_len(@line404))
    @r = assert_eq_int("parse status 404", @s, 404)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 3) Status 500.
    @line500 = "HTTP/1.0 500 Internal Server Error\r\n"
    @s = _http_parse_status(@line500, str_len(@line500))
    @r = assert_eq_int("parse status 500", @s, 500)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 4) Garbage -> -1 (too short).
    @s = _http_parse_status("hi", 2)
    @r = assert_eq_int("garbage too short", @s, -1)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 5) Header separator finder.
    @resp = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nhello"
    @off = _http_find_crlf_crlf(@resp, str_len(@resp))
    @r = assert_eq_int("crlf-crlf offset", @off, 34)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 6) Header separator missing -> -1.
    @noterm = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\nhello"
    @off = _http_find_crlf_crlf(@noterm, str_len(@noterm))
    @r = assert_eq_int("no separator -> -1", @off, -1)
    @p = @p + @r
    @f = @f + (1 - @r)

    # 7) Integer formatter.
    @r = assert_eq_str("int_to_str 0", _http_int_to_str(0), "0")
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_str("int_to_str 5", _http_int_to_str(5), "5")
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_str("int_to_str 1024", _http_int_to_str(1024), "1024")
    @p = @p + @r
    @f = @f + (1 - @r)

    # 8) Connection-refused path returns status -1 (not a crash).
    let @resp_ref: HttpResponse = http_get("127.0.0.1", 1, "/")
    @r = assert_eq_int("refused -> status -1", @resp_ref.status, -1)
    @p = @p + @r
    @f = @f + (1 - @r)

    test_summary("http", @p, @f)
    if @f > 0
        return 1
    return 0


fn main() -> int
    return run_http_tests(0, 0)
