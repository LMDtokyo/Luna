# Standalone DNS resolution test.
#
# Queries 8.8.8.8 for "one.one.one.one" — Cloudflare's anycast
# hostname that always resolves to 1.1.1.1 or 1.0.0.1. Exits 0 on
# a match, 1 otherwise.

import dns


fn main() -> int
    @ip = dns_resolve("one.one.one.one")
    if str_len(@ip) == 0
        shine("FAIL: empty IP")
        return 1
    if str_eq(@ip, "1.1.1.1") == 1
        shine("PASS: one.one.one.one -> 1.1.1.1")
        return 0
    if str_eq(@ip, "1.0.0.1") == 1
        shine("PASS: one.one.one.one -> 1.0.0.1")
        return 0
    shine("FAIL: unexpected IP:")
    shine(@ip)
    return 1
