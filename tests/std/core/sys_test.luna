# Tests for std/core/sys.

import sys
import test


fn run_sys_tests(@p: int, @f: int) -> int
    @r = 0

    # arg(0) is the program path; never empty when invoked normally.
    @prog = program_name()
    @r = assert_true("program_name non-empty", str_len(@prog) > 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # args_count includes arg(0), so >= 1.
    @n = args_count()
    @r = assert_true("args_count >= 1", @n >= 1)
    @p = @p + @r
    @f = @f + (1 - @r)

    # args_collect length equals args_count.
    @v = args_collect()
    @r = assert_eq_int("args_collect length", vec_len(@v), @n)
    @p = @p + @r
    @f = @f + (1 - @r)

    # args_user is args_collect minus arg(0).
    @vu = args_user()
    @r = assert_eq_int("args_user length", vec_len(@vu), @n - 1)
    @p = @p + @r
    @f = @f + (1 - @r)

    test_summary("sys", @p, @f)
    if @f > 0
        return 1
    return 0


fn main() -> int
    return run_sys_tests(0, 0)
