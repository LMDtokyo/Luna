# tests/std/ext/compress/gzip_test.luna
#
# Verifies the gzip/deflate decoder. The first half of the suite
# constructs valid gzip streams in-process (stored DEFLATE block +
# RFC 1952 envelope with a real CRC32 footer) so it always runs; the
# second half reads fixtures generated by gzip_e2e.sh from
# /tmp/luna_gzip_fixtures/* to exercise the fixed-/dynamic-Huffman
# code paths against the system `gzip` reference encoder.
#
# When run without the e2e wrapper, the fixture-dependent assertions
# are skipped (counted as 0 PASS / 0 FAIL) so `tests/run_all.sh`
# doesn't report spurious failures.

import gzip
import test


# _read_all(@path) -> file contents as bytes, or "" if open/read fails.
fn _read_all(@path: int) -> int
    @fd = sys_open(@path, 0, 0)
    if @fd < 0
        return ""
    @cap = 1048576
    @buf = new_str(@cap)
    @total = 0
    while @total < @cap
        @r = sys_read(@fd, @buf + @total, @cap - @total)
        if @r <= 0
            break
        @total = @total + @r
    sys_close(@fd)
    return str_substr(@buf, 0, @total)


# _all_bytes() -> string containing every byte value 0..255 in order.
# Used to check the decoder doesn't accidentally trim NULs or assume
# UTF-8.
fn _all_bytes() -> int
    @s = new_str(256)
    @i = 0
    while @i < 256
        u8_set(@s, @i, @i)
        @i = @i + 1
    return @s


# _make_stored_gzip(@plain) -> bytes of a complete gzip stream wrapping
# a single BTYPE=0 stored DEFLATE block. We construct these in-process
# so the test isn't dependent on the system `gzip` command — the
# fixture-based assertions below cover the Huffman code paths instead.
fn _make_stored_gzip(@plain: int) -> int
    @n = str_len(@plain)
    @total = 10 + 5 + @n + 8
    @buf = new_str(@total)
    # gzip header: magic + deflate + no flags (mtime/xfl/os stay zero).
    u8_set(@buf, 0, 31)
    u8_set(@buf, 1, 139)
    u8_set(@buf, 2, 8)
    # Stored block header: BFINAL=1 BTYPE=00 = 0x01, then LEN + ~LEN.
    u8_set(@buf, 10, 1)
    u8_set(@buf, 11, @n & 255)
    u8_set(@buf, 12, (@n >> 8) & 255)
    @nlen = @n ^ 65535
    u8_set(@buf, 13, @nlen & 255)
    u8_set(@buf, 14, (@nlen >> 8) & 255)
    @i = 0
    while @i < @n
        u8_set(@buf, 15 + @i, str_byte(@plain, @i))
        @i = @i + 1
    # Footer: CRC32 + ISIZE, both little-endian.
    @crc = _crc32(@plain)
    @fp = 15 + @n
    u8_set(@buf, @fp, @crc & 255)
    u8_set(@buf, @fp + 1, (@crc >> 8) & 255)
    u8_set(@buf, @fp + 2, (@crc >> 16) & 255)
    u8_set(@buf, @fp + 3, (@crc >> 24) & 255)
    @isize = @n & 4294967295
    u8_set(@buf, @fp + 4, @isize & 255)
    u8_set(@buf, @fp + 5, (@isize >> 8) & 255)
    u8_set(@buf, @fp + 6, (@isize >> 16) & 255)
    u8_set(@buf, @fp + 7, (@isize >> 24) & 255)
    return @buf


fn run_gzip_tests(@p: int, @f: int) -> int
    @r = 0

    # ---- Self-contained assertions (no external fixtures) ----

    # is_gzip detection on the magic bytes.
    @magic = new_str(2)
    u8_set(@magic, 0, 31)
    u8_set(@magic, 1, 139)
    @r = assert_eq_int("is_gzip magic", is_gzip(@magic), 1)
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_int("is_gzip non-magic", is_gzip("hello"), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_int("is_gzip too short", is_gzip(""), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Stored-block round-trips of varying sizes.
    @r = assert_eq_str("stored empty", gzip_decompress(_make_stored_gzip("")), "")
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_str("stored short", gzip_decompress(_make_stored_gzip("Hello, world!")), "Hello, world!")
    @p = @p + @r
    @f = @f + (1 - @r)

    # Byte-clean coverage: every value 0..255.
    @all = _all_bytes()
    @r = assert_eq_str("stored all bytes", gzip_decompress(_make_stored_gzip(@all)), @all)
    @p = @p + @r
    @f = @f + (1 - @r)

    # ~8 KB blob still fits in a single stored block (LEN field is u16).
    @big = ""
    @bi = 0
    while @bi < 256
        @big = str_concat(@big, "0123456789abcdef0123456789ABCDEF")
        @bi = @bi + 1
    @r = assert_eq_str("stored 8KB", gzip_decompress(_make_stored_gzip(@big)), @big)
    @p = @p + @r
    @f = @f + (1 - @r)

    # CRC32 tamper detection.
    @gz_crc = _make_stored_gzip("CRC me")
    u8_set(@gz_crc, str_len(@gz_crc) - 8, 99)
    @r = assert_eq_str("crc tamper empty", gzip_decompress(@gz_crc), "")
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_true("crc tamper error", str_len(gzip_error()))
    @p = @p + @r
    @f = @f + (1 - @r)

    # Bad magic.
    @r = assert_eq_str("bad magic empty", gzip_decompress("definitely not gzip"), "")
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_true("bad magic error", str_len(gzip_error()))
    @p = @p + @r
    @f = @f + (1 - @r)

    # Truncated input.
    @full = _make_stored_gzip("longer payload for truncation test")
    @trunc = str_substr(@full, 0, str_len(@full) - 4)
    @r = assert_eq_str("trunc empty", gzip_decompress(@trunc), "")
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_true("trunc error", str_len(gzip_error()))
    @p = @p + @r
    @f = @f + (1 - @r)

    # A successful call wipes any previous error.
    @plain_ok = gzip_decompress(_make_stored_gzip("X"))
    @r = assert_eq_int("success clears error", str_len(gzip_error()), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # ---- Fixture-dependent assertions (run only under gzip_e2e.sh) ----

    @gz_hello = _read_all("/tmp/luna_gzip_fixtures/hello.gz")
    if str_len(@gz_hello) == 0
        shine("[gzip] (skipping fixture-based assertions — run gzip_e2e.sh for full coverage)")
        test_summary("gzip", @p, @f)
        if @f > 0
            return 1
        return 0

    # Fixed-Huffman block from `printf hello | gzip -c`.
    @r = assert_eq_str("fixture hello", gzip_decompress(@gz_hello), "hello")
    @p = @p + @r
    @f = @f + (1 - @r)

    # Highly repetitive — exercises LZ77 back-references.
    @gz_rep = _read_all("/tmp/luna_gzip_fixtures/rep.gz")
    @want_rep = ""
    @ri = 0
    while @ri < 64
        @want_rep = str_concat(@want_rep, "AAAAAAAAAAAAAAAA")
        @ri = @ri + 1
    @r = assert_eq_str("fixture repetitive", gzip_decompress(@gz_rep), @want_rep)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Longer English text — exercises dynamic Huffman.
    @gz_text = _read_all("/tmp/luna_gzip_fixtures/text.gz")
    @want_text = _read_all("/tmp/luna_gzip_fixtures/text.raw")
    @r = assert_eq_str("fixture text", gzip_decompress(@gz_text), @want_text)
    @p = @p + @r
    @f = @f + (1 - @r)

    # ~100 KB multi-block stream.
    @gz_big = _read_all("/tmp/luna_gzip_fixtures/big.gz")
    @want_big = _read_all("/tmp/luna_gzip_fixtures/big.raw")
    @r = assert_eq_int("fixture big length", str_len(gzip_decompress(@gz_big)), str_len(@want_big))
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_str("fixture big content", gzip_decompress(@gz_big), @want_big)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Byte-clean round-trip through the real gzip encoder.
    @gz_all = _read_all("/tmp/luna_gzip_fixtures/allbytes.gz")
    @r = assert_eq_str("fixture all bytes", gzip_decompress(@gz_all), @all)
    @p = @p + @r
    @f = @f + (1 - @r)

    test_summary("gzip", @p, @f)
    if @f > 0
        return 1
    return 0


fn main() -> int
    return run_gzip_tests(0, 0)
