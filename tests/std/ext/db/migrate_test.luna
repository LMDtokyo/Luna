# Tests for std/ext/db/migrate — sequential SQLite schema versioning.

import sqlite
import migrate
import test


fn _testdb() -> int
    return "/tmp/luna-migrate-test.db"

fn _cleanup() -> int
    shell_run("rm -f /tmp/luna-migrate-test.db /tmp/luna-sqlite-sql.txt /tmp/luna-sqlite-out.txt")
    return 0


fn run_migrate_tests(@p: int, @f: int) -> int
    @r = 0
    _cleanup()
    @h = db_open(_testdb())

    # Fresh DB: version 0.
    @r = assert_eq_int("v0 fresh", db_migrate_version(@h), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Apply migrations 1, 2, 3.
    @ms = vec_new()
    migrate_push(@ms, 1, "CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT)")
    migrate_push(@ms, 2, "CREATE INDEX users_by_name ON users(name)")
    migrate_push(@ms, 3, "ALTER TABLE users ADD COLUMN email TEXT")
    @n = db_migrate(@h, @ms)
    @r = assert_eq_int("3 applied", @n, 3)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("v3 after", db_migrate_version(@h), 3)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Schema actually got the new column.
    db_exec(@h, "INSERT INTO users (name, email) VALUES ('alice', 'a@x.com')")
    @r = assert_eq_str("email persisted", db_scalar(@h, "SELECT email FROM users WHERE name='alice'"), "a@x.com")
    @p = @p + @r
    @f = @f + (1 - @r)

    # Re-running same migrations: zero new applied.
    @n = db_migrate(@h, @ms)
    @r = assert_eq_int("idempotent", @n, 0)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("v3 unchanged", db_migrate_version(@h), 3)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Add migration 4, replay: only 1 new applied.
    migrate_push(@ms, 4, "CREATE TABLE posts (id INTEGER PRIMARY KEY, user_id INTEGER, body TEXT)")
    @n = db_migrate(@h, @ms)
    @r = assert_eq_int("1 new", @n, 1)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("v4 after", db_migrate_version(@h), 4)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Bookkeeping table has 4 rows.
    @count = db_scalar(@h, "SELECT COUNT(*) FROM _luna_migrations")
    @r = assert_eq_str("4 rows recorded", @count, "4")
    @p = @p + @r
    @f = @f + (1 - @r)

    db_close(@h)
    _cleanup()
    test_summary("migrate", @p, @f)
    if @f > 0
        return 1
    return 0


fn main() -> int
    return run_migrate_tests(0, 0)
