# tests/std/ext/image/png_test.luna
#
# Verifies the PNG decoder against fixtures generated by png_e2e.sh.
# Self-contained checks (signature detection, error reset) are run
# unconditionally so this file passes under `tests/run_all.sh` even
# when ImageMagick isn't installed; the fixture-dependent assertions
# are skipped (counted as 0 PASS / 0 FAIL) in that case.

import png
import test


# _read_all(@path) -> file contents as bytes, or "" if open/read fails.
fn _read_all(@path: int) -> int
    @fd = sys_open(@path, 0, 0)
    if @fd < 0
        return ""
    @cap = 4194304
    @buf = new_str(@cap)
    @total = 0
    while @total < @cap
        @r = sys_read(@fd, @buf + @total, @cap - @total)
        if @r <= 0
            break
        @total = @total + @r
    sys_close(@fd)
    return str_substr(@buf, 0, @total)


# _mk_sig() -> 8-byte PNG signature buffer (for is_png tests).
fn _mk_sig() -> int
    @s = new_str(8)
    u8_set(@s, 0, 137)
    u8_set(@s, 1, 80)
    u8_set(@s, 2, 78)
    u8_set(@s, 3, 71)
    u8_set(@s, 4, 13)
    u8_set(@s, 5, 10)
    u8_set(@s, 6, 26)
    u8_set(@s, 7, 10)
    return @s


# _channel(@px, @shift) -> extract one byte from a packed pixel.
fn _channel(@px: int, @shift: int) -> int
    return (@px >> @shift) & 255


fn run_png_tests(@p: int, @f: int) -> int
    @r = 0

    # ---- Self-contained assertions (no external fixtures) ----

    @r = assert_eq_int("is_png on signature", is_png(_mk_sig()), 1)
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_int("is_png on garbage", is_png("not a png at all"), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_int("is_png on empty", is_png(""), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    @r = assert_eq_int("is_png on 7-byte truncated", is_png("ABCDEFG"), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Bad signature -> -1, error set.
    @bad = png_decode("definitely not a png file")
    @r = assert_eq_int("bad sig returns -1", @bad, -1)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_true("bad sig error nonempty", str_len(png_error()))
    @p = @p + @r
    @f = @f + (1 - @r)

    # Just the signature, no chunks -> truncated.
    @sig_only = _mk_sig()
    @r = assert_eq_int("sig-only returns -1", png_decode(@sig_only), -1)
    @p = @p + @r
    @f = @f + (1 - @r)

    # ---- Fixture-dependent assertions (run only under png_e2e.sh) ----

    @bytes_rgb1 = _read_all("/tmp/luna_png_fixtures/rgb1.png")
    if str_len(@bytes_rgb1) == 0
        shine("[png] (skipping fixture-based assertions — run png_e2e.sh for full coverage)")
        test_summary("png", @p, @f)
        if @f > 0
            return 1
        return 0

    # Fixture 1: 1x1 solid red. ImageMagick may produce RGB or RGBA;
    # either is acceptable. We just check dims and that the pixel is red.
    @raw_img1 = png_decode(@bytes_rgb1)
    @r = assert_true("1x1 decode ok", @raw_img1 != -1)
    @p = @p + @r
    @f = @f + (1 - @r)
    if @raw_img1 == -1
        shine("[png] 1x1 decode failed; skipping dependent assertions")
        test_summary("png", @p, @f)
        if @f > 0
            return 1
        return 0
    let @img1: Image = @raw_img1
    @r = assert_eq_int("1x1 width", img_width(@img1), 1)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("1x1 height", img_height(@img1), 1)
    @p = @p + @r
    @f = @f + (1 - @r)
    @px1 = img_pixel(@img1, 0, 0)
    @r = assert_eq_int("1x1 red channel", _channel(@px1, 24), 255)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("1x1 green channel", _channel(@px1, 16), 0)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("1x1 blue channel", _channel(@px1, 8), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Fixture 2: 4x4 RGBA with a known alpha pattern (a fully-opaque red
    # tile produced with the "rgba(255,0,0,1)" syntax). We expect 4
    # channels and full opacity.
    @bytes_rgba4 = _read_all("/tmp/luna_png_fixtures/rgba4.png")
    @raw_img2 = png_decode(@bytes_rgba4)
    @r = assert_true("4x4 decode ok", @raw_img2 != -1)
    @p = @p + @r
    @f = @f + (1 - @r)
    if @raw_img2 == -1
        shine("[png] 4x4 decode failed; skipping dependent assertions")
        test_summary("png", @p, @f)
        if @f > 0
            return 1
        return 0
    let @img2: Image = @raw_img2
    @r = assert_eq_int("4x4 width", img_width(@img2), 4)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("4x4 height", img_height(@img2), 4)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("4x4 channels", img_channels(@img2), 4)
    @p = @p + @r
    @f = @f + (1 - @r)
    # Center pixel should still be red, alpha=255.
    @px2 = img_pixel(@img2, 2, 2)
    @r = assert_eq_int("4x4 alpha=255", _channel(@px2, 0), 255)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_eq_int("4x4 red=255", _channel(@px2, 24), 255)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Fixture 3: large image that ImageMagick splits across multiple
    # IDAT chunks (gradient → high entropy → big payload). We don't
    # check exact pixel values, just that decoding succeeds and the
    # pixel buffer is the expected size.
    @bytes_big = _read_all("/tmp/luna_png_fixtures/big.png")
    @raw_img3 = png_decode(@bytes_big)
    @r = assert_true("multi-IDAT decode ok", @raw_img3 != -1)
    @p = @p + @r
    @f = @f + (1 - @r)
    if @raw_img3 == -1
        shine("[png] multi-IDAT decode failed; skipping dependent assertions")
        test_summary("png", @p, @f)
        if @f > 0
            return 1
        return 0
    let @img3: Image = @raw_img3
    @bw = img_width(@img3)
    @bh = img_height(@img3)
    @bc = img_channels(@img3)
    @want_len = @bw * @bh * @bc
    @r = assert_eq_int("multi-IDAT pixel buffer length", str_len(img_pixels(@img3)), @want_len)
    @p = @p + @r
    @f = @f + (1 - @r)

    # Truncated input: drop the last 30 bytes of a known-good PNG.
    @trunc = str_substr(@bytes_big, 0, str_len(@bytes_big) - 30)
    @r = assert_eq_int("truncated returns -1", png_decode(@trunc), -1)
    @p = @p + @r
    @f = @f + (1 - @r)
    @r = assert_true("truncated error nonempty", str_len(png_error()))
    @p = @p + @r
    @f = @f + (1 - @r)

    # Success after failure clears the error string.
    @ok = png_decode(@bytes_rgb1)
    @r = assert_eq_int("success clears error", str_len(png_error()), 0)
    @p = @p + @r
    @f = @f + (1 - @r)

    test_summary("png", @p, @f)
    if @f > 0
        return 1
    return 0


fn main() -> int
    return run_png_tests(0, 0)
