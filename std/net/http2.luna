# tier: T5
# deps: tcp, dns
# ffi: none
#
# std/net/http2 — HTTP/2 cleartext (H2C) client in pure Luna.
#
# Scope (MVP — see PR notes):
#   * Connection preface ("PRI * HTTP/2.0\r\n\r\nSM\r\n\r\n") + initial
#     empty SETTINGS frame (prior-knowledge h2c, no Upgrade dance, no TLS).
#   * Frame format: 9-byte header (length:24, type:8, flags:8,
#     R:1+stream_id:31) followed by payload.
#   * Frame types handled: DATA(0), HEADERS(1), SETTINGS(4), PING(6),
#     GOAWAY(7), WINDOW_UPDATE(8). Other frame types (PRIORITY,
#     RST_STREAM, PUSH_PROMISE, CONTINUATION) are silently consumed.
#   * HPACK encoding: every header emitted as "literal without indexing"
#     (0x00 + length-prefixed name + length-prefixed value, length is
#     a 7-bit unsigned prefix per RFC 7541 §5.1 — string fits if len < 127).
#   * HPACK decoding: handles indexed (1xxxxxxx) lookup against the
#     static table, "literal with incremental indexing" (01xxxxxx),
#     "literal without indexing" (0000xxxx), and "literal never
#     indexed" (0001xxxx). Huffman-encoded strings -> error. Dynamic
#     table updates are accepted parse-wise but the dynamic table is
#     NOT populated (matches the spec's "static-only" promise; servers
#     that depend on dynamic indexing for response headers will lose
#     header fidelity).
#   * Response collection: read frames until END_STREAM on our stream.
#     Concatenate DATA payloads into the body. SETTINGS/PING/WINDOW
#     frames from server are auto-acked. GOAWAY ends the connection.
#
# Out of scope (deferred):
#   * Server push, priority, CONTINUATION, alt-svc.
#   * Multiple in-flight streams on one connection. The client API is
#     sequential: one h2_request at a time (next_stream_id increments
#     so multiple sequential requests are fine).
#   * Huffman coding (encoding always emits literals; decoding rejects).
#   * Dynamic HPACK table.
#   * ALPN / TLS — H2 over TLS lands when TLS 1.3 does.
#
# Public API:
#     fn h2_connect(@host: int, @port: int) -> int
#     fn h2_request(@conn: int, @method: int, @path: int, @host: int, @body: int) -> int
#     fn h2_request_with_headers(@conn: int, @method: int, @path: int,
#                                @host: int, @headers: int, @body: int) -> int
#     fn h2_status(@resp: int) -> int
#     fn h2_header(@resp: int, @name: int) -> int
#     fn h2_body(@resp: int) -> int
#     fn h2_close(@conn: int) -> int
#     fn h2_error() -> int
#
# Caller gotcha:
#   The handle types (H2Conn / H2Response) are structs. The functions
#   above hide that — they take/return int pointers and accept any
#   int-shaped value. Internally they cast via `let @c: H2Conn = ...`.

import tcp
import dns


# Frame types.
const H2_FRAME_DATA:           int = 0
const H2_FRAME_HEADERS:        int = 1
const H2_FRAME_PRIORITY:       int = 2
const H2_FRAME_RST_STREAM:     int = 3
const H2_FRAME_SETTINGS:       int = 4
const H2_FRAME_PUSH_PROMISE:   int = 5
const H2_FRAME_PING:           int = 6
const H2_FRAME_GOAWAY:         int = 7
const H2_FRAME_WINDOW_UPDATE:  int = 8
const H2_FRAME_CONTINUATION:   int = 9

# Frame flags (per-type — fortunately the bits we care about don't collide).
const H2_FLAG_END_STREAM:  int = 1
const H2_FLAG_ACK:         int = 1
const H2_FLAG_END_HEADERS: int = 4
const H2_FLAG_PADDED:      int = 8
const H2_FLAG_PRIORITY:    int = 32

# Limits.
const H2_MAX_BODY:    int = 1048576
const H2_RECV_BUF:    int = 16384


# H2Conn — handle returned by h2_connect.
#   fd:              connected TCP socket (or -1).
#   next_stream_id:  next client stream id (odd: 1, 3, 5, ...).
#   error:           last error string (used by h2_error()).
struct H2Conn
    fd:             int
    next_stream_id: int
    error:          int


# H2Response — handle returned by h2_request.
#   status:    HTTP status code, or -1 on parse/protocol failure.
#   names:     Vec of header-name strings (lowercase).
#   values:    Vec of header-value strings.
#   body:      response body bytes.
#   stream_id: the stream id used (debug aid).
struct H2Response
    status:    int
    names:     int
    values:    int
    body:      int
    stream_id: int


# Last-error storage. Bootminor has no module-static variables, so we
# reserve a single page at a fixed virtual address (high enough to be
# clear of text, heap, and stack) via mmap with MAP_FIXED_NOREPLACE.
# The flag means the first call wins; subsequent calls hit EEXIST,
# which we treat as success (the page is already mapped and ours).
#
# Requires Linux >= 4.17 for MAP_FIXED_NOREPLACE. Bootminor is Linux/
# x86_64-only anyway, so that's fine.

const H2_ERR_SLOT_ADDR: int = 0x600000000000
const H2_ERR_SLOT_LEN:  int = 4096
# MAP_PRIVATE(2) | MAP_ANONYMOUS(0x20) | MAP_FIXED_NOREPLACE(0x100000)
const H2_ERR_SLOT_FLAGS: int = 1048626

# _h2_err_addr() -> stable 8-byte address that holds the last error
# string pointer. Returns 0 if mmap fails.
fn _h2_err_addr() -> int
    @p = sys_mmap(H2_ERR_SLOT_ADDR, H2_ERR_SLOT_LEN, 3, H2_ERR_SLOT_FLAGS, 0 - 1, 0)
    # Success: mmap returns the chosen address (== H2_ERR_SLOT_ADDR).
    # EEXIST (-17): page already mapped by us on a prior call — still
    # usable. Other errno: real failure.
    if @p == H2_ERR_SLOT_ADDR
        return H2_ERR_SLOT_ADDR
    if @p == 0 - 17
        return H2_ERR_SLOT_ADDR
    return 0

# Set the process-wide last error. Falls back to no-op if sys_brk
# fails (which would be exotic).
fn _h2_set_error_global(@msg: int) -> int
    @addr = _h2_err_addr()
    if @addr == 0
        return 0
    # Store the pointer at byte offset 0. Pointers are 8 bytes; we
    # write them little-endian via per-byte u8_set.
    @p = @msg
    @i = 0
    while @i < 8
        u8_set(@addr, @i, @p & 255)
        @p = @p >> 8
        @i = @i + 1
    return 0

# h2_error() — return the last error string set globally. Empty
# string if nothing has failed.
fn h2_error() -> int
    @addr = _h2_err_addr()
    if @addr == 0
        return ""
    @p = 0
    @i = 0
    while @i < 8
        @b = u8_at(@addr, @i)
        @p = @p | (@b << (@i * 8))
        @i = @i + 1
    if @p == 0
        return ""
    return @p


# === HPACK static table =================================================
#
# Per RFC 7541 Appendix A. Index 1..61 (we expose 0-based internally
# but the wire uses 1-based). The table is built once on demand.
# Names are lowercase ASCII; some entries have a value, others have
# an empty value (means: the wire encoding pairs that name with a
# literal value supplied inline).
fn _h2_static_names() -> int
    @v = vec_new()
    vec_push(@v, ":authority")
    vec_push(@v, ":method")
    vec_push(@v, ":method")
    vec_push(@v, ":path")
    vec_push(@v, ":path")
    vec_push(@v, ":scheme")
    vec_push(@v, ":scheme")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, ":status")
    vec_push(@v, "accept-charset")
    vec_push(@v, "accept-encoding")
    vec_push(@v, "accept-language")
    vec_push(@v, "accept-ranges")
    vec_push(@v, "accept")
    vec_push(@v, "access-control-allow-origin")
    vec_push(@v, "age")
    vec_push(@v, "allow")
    vec_push(@v, "authorization")
    vec_push(@v, "cache-control")
    vec_push(@v, "content-disposition")
    vec_push(@v, "content-encoding")
    vec_push(@v, "content-language")
    vec_push(@v, "content-length")
    vec_push(@v, "content-location")
    vec_push(@v, "content-range")
    vec_push(@v, "content-type")
    vec_push(@v, "cookie")
    vec_push(@v, "date")
    vec_push(@v, "etag")
    vec_push(@v, "expect")
    vec_push(@v, "expires")
    vec_push(@v, "from")
    vec_push(@v, "host")
    vec_push(@v, "if-match")
    vec_push(@v, "if-modified-since")
    vec_push(@v, "if-none-match")
    vec_push(@v, "if-range")
    vec_push(@v, "if-unmodified-since")
    vec_push(@v, "last-modified")
    vec_push(@v, "link")
    vec_push(@v, "location")
    vec_push(@v, "max-forwards")
    vec_push(@v, "proxy-authenticate")
    vec_push(@v, "proxy-authorization")
    vec_push(@v, "range")
    vec_push(@v, "referer")
    vec_push(@v, "refresh")
    vec_push(@v, "retry-after")
    vec_push(@v, "server")
    vec_push(@v, "set-cookie")
    vec_push(@v, "strict-transport-security")
    vec_push(@v, "transfer-encoding")
    vec_push(@v, "user-agent")
    vec_push(@v, "vary")
    vec_push(@v, "via")
    vec_push(@v, "www-authenticate")
    return @v

fn _h2_static_values() -> int
    @v = vec_new()
    vec_push(@v, "")
    vec_push(@v, "GET")
    vec_push(@v, "POST")
    vec_push(@v, "/")
    vec_push(@v, "/index.html")
    vec_push(@v, "http")
