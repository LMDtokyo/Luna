# tier: T6
# deps:
# ffi: none
#
# std/ext/crypto/aes_gcm — AES-128-GCM and AES-256-GCM (NIST SP 800-38D)
# in pure Luna. No FFI; only bootminor string + bitop intrinsics.
#
# Public API:
#   aes_gcm_encrypt(@key, @nonce, @plaintext, @aad) -> ciphertext || tag (16-byte tag appended)
#   aes_gcm_decrypt(@key, @nonce, @cipher_plus_tag, @aad) -> plaintext, or "" on auth failure
#   aes_gcm_check_inputs(@key, @nonce) -> 1 if key is 16 or 32 bytes and nonce is 12 bytes
#   aes_gcm_hex(@bytes) -> lowercase hex
#
# Nonce MUST be 12 bytes (96 bits). Key MUST be 16 (AES-128) or 32 (AES-256).
# Variant is auto-detected from key length.
#
# Implementation notes:
#   - AES S-box and round constants are built lazily as byte buffers
#     (no 256-element int literal lists to avoid lexer pressure).
#   - GHASH multiplies in GF(2^128) via bit-by-bit shift-XOR. Slow but
#     correct; ~1024 ops per 16-byte block. Adequate for stdlib use.
#   - Counter mode increments the last 4 bytes of J0 as big-endian u32.


# --- AES S-box --------------------------------------------------------
#
# Pre-built into a 256-byte string buffer the first time someone calls
# _aes_sbox / _aes_inv_sbox. Cached via a 1-cell vec.

fn _aes_build_sbox() -> int
    @s = new_str(256)
    # Standard FIPS-197 S-box, 16 rows of 16 bytes.
    str_set_byte(@s,   0,  99)
    str_set_byte(@s,   1, 124)
    str_set_byte(@s,   2, 119)
    str_set_byte(@s,   3, 123)
    str_set_byte(@s,   4, 242)
    str_set_byte(@s,   5, 107)
    str_set_byte(@s,   6, 111)
    str_set_byte(@s,   7, 197)
    str_set_byte(@s,   8,  48)
    str_set_byte(@s,   9,   1)
