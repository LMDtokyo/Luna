# =============================================================================
# Discord Bot (cosmic edition) — Luna v4.3
# =============================================================================
# Connects to Discord Gateway v10 over a secure cascade (WSS), identifies as
# a bot, and replies "pong" to any message that starts with "!ping".
#
# Uses:
#   * cascade         — bi-directional pulse chain (was WebSocket)
#   * beam            — HTTP for REST replies (was http)
#   * lumen           — JSON (was json)
#   * chrono          — moments and arcs (was time)
#   * cosmos          — env vars (was getenv)
#   * nebula.spawn    — structured concurrency for the heartbeat pulse
#
# The phase<T> / `?` propagator drastically shortens the original bot, and
# `nebula.spawn` keeps the heartbeat alive in a sibling fibre that shares
# the parent's cascade handle.
# =============================================================================

import cascade      # was websocket
import beam         # was http
import lumen        # was json
import chrono       # was time
import cosmos       # was env
import nebula       # was scheduler (spawn / pulse)

# ---------------------------------------------------------------------------
# Gateway op codes and intents (unchanged — these come from Discord's spec)
# ---------------------------------------------------------------------------

const OP_DISPATCH:         int = 0
const OP_HEARTBEAT:        int = 1
const OP_IDENTIFY:         int = 2
const OP_RESUME:           int = 6
const OP_RECONNECT:        int = 7
const OP_INVALID_SESSION:  int = 9
const OP_HELLO:            int = 10
const OP_HEARTBEAT_ACK:    int = 11

const INTENT_GUILD_MESSAGES:  int = 512       # 1 << 9
const INTENT_MESSAGE_CONTENT: int = 32768     # 1 << 15

seal @gateway_url = "wss://gateway.discord.gg/?v=10&encoding=json"
seal @api_base    = "https://discord.com/api/v10"

# ---------------------------------------------------------------------------
# Identify frame
# ---------------------------------------------------------------------------

fn identify_frame(@token: str, @intents: int) -> lumen.Node
    return lumen.compose
        "op": 2
        "d":
            "token":      @token
            "intents":    @intents
            "properties":
                "os":      "luna"
                "browser": "luna"
                "device":  "luna"

fn heartbeat_frame(@last_seq: seen<int>) -> lumen.Node
    return lumen.compose
        "op": 1
        "d":  @last_seq                       # lumen.compose serialises `Gone` as null

# ---------------------------------------------------------------------------
# REST reply
# ---------------------------------------------------------------------------

fn send_message(@token: str, @channel: str, @content: str) -> phase<unit>
    seal @url = @api_base + "/channels/" + @channel + "/messages"
    seal @body = lumen.compose
        "content": @content
    seal @echo = beam.push_lumen_with_auth(@url, @body, "Bot " + @token)?
    unless @echo.status.is_ok()
        shine Dim(Fault.net("discord: " + @echo.status.show()))
    shine Bright(unit)

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

fn main() -> phase<int>
    seal @token = cosmos.peek("DISCORD_BOT_TOKEN")?
    shine "luna-discord waking the cascade..."

    # Open the secure cascade (TLS-wrapped WebSocket).
    meow @cx: cascade.Link = cascade.link_secure(@gateway_url)?

    # Wait for HELLO and extract heartbeat_interval.
    seal @hello = @cx.catch()?                # phase<Frame>
    seal @hello_doc = lumen.parse(@hello.carry)?
    guard @hello_doc.at("op")?.as_int()? == OP_HELLO
        else shine Dim(Fault.net("expected HELLO, got different op"))
    seal @heartbeat_ms = @hello_doc.at("d")?.at("heartbeat_interval")?.as_int()?

    # Send IDENTIFY.
    @cx.emit_lumen(identify_frame(@token, INTENT_GUILD_MESSAGES | INTENT_MESSAGE_CONTENT))?

    # Shared state between the main loop and the heartbeat sibling.
    meow @last_seq: seen<int> = Gone
    meow @running: beacon = beacon.new(1)

    # Heartbeat pulses in a sibling fibre.  beacon + seen<int> keep it safe.
    nebula.spawn
        orbit _ in 0..9999999999
            guard @running.read() == 1 else break
            chrono.slumber(arc.millis(@heartbeat_ms))
            @cx.emit_lumen(heartbeat_frame(@last_seq))
                ?? pass       # silently drop; recv loop will notice the close
    # The `??` above is `seen_or(..., pass)`: if the pulse dies, we do
    # nothing rather than collapse.  The main loop handles reconnection.

    # Main event loop
    orbit _ in 0..9999999999
        phase @cx.catch()
            Bright(@frame) =>
                seal @ev = lumen.parse(@frame.carry)?
                seal @op  = @ev.at("op")?.as_int()?
                seal @seq = @ev.at("s").as_int()
                phase @seq
                    Here(@n) => @last_seq = Here(@n)
                    Gone     => pass

                if @op == OP_HEARTBEAT_ACK
                    pass          # ack — no action needed
                eclipse if @op == OP_HEARTBEAT
                    @cx.emit_lumen(heartbeat_frame(@last_seq))?
                eclipse if @op == OP_RECONNECT or @op == OP_INVALID_SESSION
                    shine "discord: gateway wants a reconnect"
                    break
                eclipse if @op == OP_DISPATCH
                    seal @t = @ev.at("t")?.as_text()?
                    if @t == "MESSAGE_CREATE"
                        seal @d = @ev.at("d")?
                        seal @channel = @d.at("channel_id")?.as_text()?
                        seal @content = @d.at("content")?.as_text()?
                        if @content.starts_with("!ping")
                            send_message(@token, @channel, "pong")?
            Dim(@fault) =>
                shine "cascade dimmed: " + @fault.msg
                break

    @running.flash(0)
    @cx.seal()
    shine Bright(0)
