# =============================================================================
# Discord Bot — Luna example
# =============================================================================
# Connects to Discord Gateway v10 over WSS, identifies with a bot token,
# listens for MESSAGE_CREATE events, and replies to "!ping" with "pong".
#
# Architecture:
#   - net.wss_connect for the Gateway socket (wss://gateway.discord.gg)
#   - http.http_post_json for REST replies (POST /channels/:id/messages)
#   - json for payload parsing
#   - time for heartbeat cadence
#
# Required env var: DISCORD_BOT_TOKEN (the bot's token from the dev portal)
# Required intents: GUILD_MESSAGES (1 << 9) | MESSAGE_CONTENT (1 << 15)
#
# Spec: https://discord.com/developers/docs/topics/gateway
# =============================================================================

import io
import net
import http
import json
import time
import scheduler

# --- Gateway constants ------------------------------------------------------

const DISCORD_API_BASE: str = "https://discord.com/api/v10"

# Op codes
const OP_DISPATCH: int          = 0
const OP_HEARTBEAT: int         = 1
const OP_IDENTIFY: int          = 2
const OP_RESUME: int            = 6
const OP_RECONNECT: int         = 7
const OP_INVALID_SESSION: int   = 9
const OP_HELLO: int             = 10
const OP_HEARTBEAT_ACK: int     = 11

# Intents — we need messages + message content
const INTENT_GUILD_MESSAGES: int   = 512       # 1 << 9
const INTENT_MESSAGE_CONTENT: int  = 32768     # 1 << 15

# Buffer sizes
const URL_BUF: int  = 4096
const BODY_BUF: int = 16384

# --- Byte-buffer helpers (shared style with telegram example) --------------

fn buf_write_str(@buf: [int; 16384], @offset: int, @s: str, @s_len: int) -> int
    orbit @i in 0..@s_len
        unsafe
            @buf[@offset + @i] = volatile_read(@s + @i)
    return @offset + @s_len

fn buf_write_int(@buf: [int; 16384], @offset: int, @n: int) -> int
    if @n == 0
        @buf[@offset] = 48
        return @offset + 1
    @tmp: [int; 20] = [0; 20]
    @t = 0
    @v = @n
    orbit _ in 0..20
        if @v == 0
            break
        @tmp[@t] = 48 + (@v % 10)
        @v = @v / 10
        @t = @t + 1
    orbit @i in 0..@t
        @buf[@offset + @i] = @tmp[@t - 1 - @i]
    return @offset + @t

# --- Gateway message helpers -----------------------------------------------

# Build IDENTIFY payload:
# { "op":2, "d": { "token":"...", "intents":N, "properties":{...} } }
fn build_identify(@out: [int; 16384], @token: str, @token_len: int, @intents: int) -> int
    @o = 0
    @o = buf_write_str(@out, @o, "{\"op\":2,\"d\":{\"token\":\"", 22)
    @o = buf_write_str(@out, @o, @token, @token_len)
    @o = buf_write_str(@out, @o, "\",\"intents\":", 12)
    @o = buf_write_int(@out, @o, @intents)
    @o = buf_write_str(@out, @o, ",\"properties\":{\"os\":\"luna\",\"browser\":\"luna\",\"device\":\"luna\"}}}", 61)
    return @o

# Build HEARTBEAT:
# { "op":1, "d": N | null }
fn build_heartbeat(@out: [int; 16384], @last_seq: int) -> int
    @o = 0
    @o = buf_write_str(@out, @o, "{\"op\":1,\"d\":", 12)
    if @last_seq < 0
        @o = buf_write_str(@out, @o, "null", 4)
    else
        @o = buf_write_int(@out, @o, @last_seq)
    @o = buf_write_str(@out, @o, "}", 1)
    return @o

# --- Discord REST: reply to a channel ---------------------------------------

fn discord_send_message(@token: str, @token_len: int,
                        @channel_id: str, @channel_id_len: int,
                        @content: str, @content_len: int) -> HttpResponse
    # URL = https://discord.com/api/v10/channels/<id>/messages
    meow @url: [int; 4096] = [0; 4096]
    @o = 0
    @o = buf_write_str(@url, @o, DISCORD_API_BASE, 29)
    @o = buf_write_str(@url, @o, "/channels/", 10)
    @o = buf_write_str(@url, @o, @channel_id, @channel_id_len)
    @o = buf_write_str(@url, @o, "/messages", 9)

    # Body = { "content": "..." }
    meow @body: [int; 16384] = [0; 16384]
    @b = 0
    @b = buf_write_str(@body, @b, "{\"content\":\"", 12)
    @b = buf_write_str(@body, @b, @content, @content_len)
    @b = buf_write_str(@body, @b, "\"}", 2)

    # Extra header: Authorization: Bot <token>
    meow @hdr: [int; 256] = [0; 256]
    @h = 0
    @h = buf_write_str(@hdr, @h, "Authorization: Bot ", 19)
    @h = buf_write_str(@hdr, @h, @token, @token_len)
    @h = buf_write_str(@hdr, @h, "\r\nContent-Type: application/json\r\n", 34)

    return http_request(METHOD_POST, @url, @o, @body, @b, @hdr, @h)

# --- Main -------------------------------------------------------------------

fn main() -> int
    # --- Read token from env ---
    meow @token: [int; 128] = [0; 128]
    @token_len = env_get("DISCORD_BOT_TOKEN", 17, @token, 128)
    if @token_len <= 0
        print_line("Error: DISCORD_BOT_TOKEN not set")
        return 1

    print_line("Luna Discord bot connecting to gateway...")

    # --- Open Gateway WSS ---
    @gateway_url = "wss://gateway.discord.gg/?v=10&encoding=json"
    @ws = wss_connect(@gateway_url, 44, 0, 0)
    if @ws < 0
        print_line("Failed to connect to Discord gateway")
        return 2

    # --- Wait for HELLO (op 10) and read heartbeat_interval ---
    @frame = ws_recv(@ws)
    if @frame < 0
        print_line("No HELLO received")
        ws_close(@ws)
        return 3

    @hello_ptr = ws_frame_payload_ptr(@ws)
    @hello_len = ws_frame_payload_len(@ws)
    @hello_root = json_parse(@hello_ptr, @hello_len)
    @op = json_get_int(@hello_root, "op", -1)
    if @op != OP_HELLO
        print_line("Expected HELLO, got different op")
        json_free(@hello_root)
        ws_close(@ws)
        return 4
    @hello_d = json_get(@hello_root, "d")
    @heartbeat_ms = json_get_int(@hello_d, "heartbeat_interval", 41250)
    json_free(@hello_root)

    # --- Send IDENTIFY ---
    meow @id_payload: [int; 16384] = [0; 16384]
    @intents = INTENT_GUILD_MESSAGES + INTENT_MESSAGE_CONTENT
    @id_len = build_identify(@id_payload, @token, @token_len, @intents)
    ws_send_text(@ws, @id_payload, @id_len)

    # --- Spawn heartbeat task ---
    meow @last_seq: int = -1
    meow @running: int = 1

    spawn
        orbit _ in 0..1000000000
            if @running == 0
                break
            sleep_ms(@heartbeat_ms)
            meow @hb: [int; 16384] = [0; 16384]
            @hb_len = build_heartbeat(@hb, @last_seq)
            ws_send_text(@ws, @hb, @hb_len)

    # --- Event loop ---
    orbit _ in 0..1000000000
        @f = ws_recv(@ws)
        if @f < 0
            print_line("Gateway closed or errored")
            break

        @op_code = ws_frame_opcode(@ws)
        # Only care about TEXT frames (opcode 0x1)
        if @op_code != 1
            continue

        @payload_ptr = ws_frame_payload_ptr(@ws)
        @payload_len = ws_frame_payload_len(@ws)
        @event = json_parse(@payload_ptr, @payload_len)
        if @event < 0
            continue

        @ev_op = json_get_int(@event, "op", -1)
        @ev_seq = json_get_int(@event, "s", -1)
        if @ev_seq >= 0
            @last_seq = @ev_seq

        if @ev_op == OP_HEARTBEAT_ACK
            # Gateway acknowledged our heartbeat
            json_free(@event)
            continue

        if @ev_op == OP_HEARTBEAT
            # Gateway requested an immediate heartbeat
            meow @hb2: [int; 16384] = [0; 16384]
            @hl = build_heartbeat(@hb2, @last_seq)
            ws_send_text(@ws, @hb2, @hl)
            json_free(@event)
            continue

        if @ev_op == OP_RECONNECT or @ev_op == OP_INVALID_SESSION
            print_line("Gateway asked to reconnect")
            json_free(@event)
            break

        if @ev_op != OP_DISPATCH
            json_free(@event)
            continue

        # --- DISPATCH events: look at t == "MESSAGE_CREATE" ---
        meow @event_name: [int; 64] = [0; 64]
        @tn = json_get_str(@event, "t", @event_name, 64)
        if @tn != 14  # "MESSAGE_CREATE" = 14 chars
            json_free(@event)
            continue
        # Verify name bytes
        @expected = "MESSAGE_CREATE"
        @match = 1
        orbit @k in 0..14
            @e = 0
            unsafe
                @e = volatile_read(@expected + @k)
            if @event_name[@k] != @e
                @match = 0
                break
        if @match == 0
            json_free(@event)
            continue

        # Extract channel_id and content
        @data = json_get(@event, "d")
        if @data < 0
            json_free(@event)
            continue

        meow @channel: [int; 64] = [0; 64]
        @chan_len = json_get_str(@data, "channel_id", @channel, 64)

        meow @content: [int; 2048] = [0; 2048]
        @content_len = json_get_str(@data, "content", @content, 2048)

        # React to "!ping"
        if @content_len >= 5
            @c0 = @content[0]
            @c1 = @content[1]
            @c2 = @content[2]
            @c3 = @content[3]
            @c4 = @content[4]
            if @c0 == 33 and @c1 == 112 and @c2 == 105 and @c3 == 110 and @c4 == 103
                discord_send_message(@token, @token_len, @channel, @chan_len, "pong", 4)

        json_free(@event)

    @running = 0
    ws_close(@ws)
    return 0
